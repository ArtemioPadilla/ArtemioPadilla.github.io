---

<!doctype html>
<html lang="en" class="dark">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Artemio Padilla - Links</title>
    <meta
      name="description"
      content="Artemio Padilla - Deep Learning Architect. Connect with me on social media."
    />
    <link rel="icon" type="image/x-icon" href="/favicon.ico" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="preload"
      as="style"
      href="https://fonts.googleapis.com/css2?family=Quicksand:wght@300;400;500;600;700&display=swap"
    />
    <link
      href="https://fonts.googleapis.com/css2?family=Quicksand:wght@300;400;500;600;700&display=swap"
      rel="stylesheet"
      media="print"
      onload="this.media='all'"
    />
    <noscript>
      <link
        href="https://fonts.googleapis.com/css2?family=Quicksand:wght@300;400;500;600;700&display=swap"
        rel="stylesheet"
      />
    </noscript>
    <script is:inline>
      const theme = localStorage.getItem("theme") || "dark";
      document.documentElement.classList.toggle("light", theme === "light");
      document.documentElement.classList.toggle("dark", theme !== "light");
    </script>
  </head>
  <body>
    <ParticlesBackground client:idle />

    <!-- Theme toggle -->
    <button
      id="links-theme-toggle"
      aria-label="Toggle theme"
    >
      <svg class="dark-icon" fill="none" stroke="currentColor" viewBox="0 0 24 24" width="18" height="18">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20.354 15.354A9 9 0 018.646 3.646 9.003 9.003 0 0012 21a9.003 9.003 0 008.354-5.646z" />
      </svg>
      <svg class="light-icon" fill="none" stroke="currentColor" viewBox="0 0 24 24" width="18" height="18" style="display:none;">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 3v1m0 16v1m9-9h-1M4 12H3m15.364 6.364l-.707-.707M6.343 6.343l-.707-.707m12.728 0l-.707.707M6.343 17.657l-.707.707M16 12a4 4 0 11-8 0 4 4 0 018 0z" />
      </svg>
    </button>

    <main class="main">
      <div class="img-container">
        <img src="/images/profile.webp" alt="Artemio Padilla" class="img" />
      </div>

      <a href="/" class="username">Artemio Padilla</a>

      <TypedTagline items={typedItems} client:load />

      <section class="some-icons-container">
        {
          socialIcons.map((link) => (
            <a
              href={link.href}
              class="some-link"
              target="_blank"
              rel="noopener noreferrer"
              aria-label={link.label}
            >
              <Fragment set:html={link.svg} />
            </a>
          ))
        }

        {
          externalLinks.map((link) => (
            <a
              href={link.href}
              class="external-link"
              target={link.href.startsWith("/") ? "_self" : "_blank"}
              rel={
                link.href.startsWith("/") ? undefined : "noopener noreferrer"
              }
            >
              <span class="external-link__icon">
                <Fragment set:html={link.icon} />
              </span>
              {link.title}
              <h2 class="external-link__header">{link.subtitle}</h2>
            </a>
          ))
        }
      </section>
    </main>
  </body>
</html>

<style>
  * {
    margin: 0;
    padding: 0;
    box-sizing: border-box;
  }

  html,
  body {
    font-family: "Quicksand", sans-serif;
    margin: 0;
    padding: 0;
    background-color: #000000;
    height: 100%;
    overflow: hidden;
    transition: background-color 0.3s ease;
  }

  :global(html.light) body {
    background-color: #fafafa;
  }

  .main {
    position: relative;
    z-index: 1;
    padding: 20px 10px;
    height: 100vh;
    overflow-y: auto;
  }

  .img-container {
    height: 200px;
    width: 200px;
    margin: 0 auto;
    padding: 1rem;
  }

  .img {
    object-fit: cover;
    overflow: hidden;
    height: 100%;
    width: 100%;
    border-radius: 50%;
    border: 2px solid white;
    transition: border-color 0.3s ease;
  }

  :global(html.light) .img {
    border-color: #27272a;
  }

  .username {
    text-align: center;
    font-size: 2rem;
    font-weight: 900;
    margin: 20px;
    display: block;
    text-decoration: none;
    color: rgb(185, 185, 185);
    transition: color 0.3s ease;
  }
  .username:hover {
    color: rgb(255, 255, 255);
  }

  :global(html.light) .username {
    color: #52525b;
  }
  :global(html.light) .username:hover {
    color: #18181b;
  }

  .some-icons-container {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: space-between;
    padding: 10px;
  }

  .some-link {
    font-size: 2rem;
    padding: 0.2rem;
    width: 50px;
    height: 50px;
    color: black;
    display: flex;
    justify-content: center;
    align-items: center;
    text-decoration: none;
    box-shadow: 1px 1px rgba(172, 172, 172, 0.5);
    border-radius: 2px;
    margin-bottom: 10px;
    background-color: rgba(255, 255, 255, 0.5);
    transition:
      transform 0.2s ease,
      box-shadow 0.2s ease,
      background-color 0.2s ease;
  }
  .some-link:hover {
    transform: scale(1.01);
    box-shadow: 3px 4px red;
    background-color: rgba(255, 255, 255, 1);
  }

  :global(html.light) .some-link {
    background-color: rgba(0, 0, 0, 0.06);
    color: #27272a;
    box-shadow: 1px 1px rgba(0, 0, 0, 0.1);
  }
  :global(html.light) .some-link:hover {
    background-color: rgba(0, 0, 0, 0.12);
    box-shadow: 3px 4px #2563eb;
  }

  .external-link {
    display: block;
    text-align: center;
    box-shadow: 2px 2px rgb(172, 172, 172);
    background-color: rgba(255, 255, 255, 0.75);
    text-decoration: none;
    color: rgb(43, 43, 43);
    padding: 10px;
    margin-top: 10px;
    border-radius: 4px;
    flex-basis: 100%;
    font-size: 1rem;
    transition:
      transform 0.2s ease,
      box-shadow 0.2s ease,
      background-color 0.2s ease;
  }
  .external-link:hover {
    transform: scale(1.01);
    box-shadow: 4px 4px red;
    background-color: rgba(255, 255, 255, 1);
  }

  :global(html.light) .external-link {
    background-color: rgba(0, 0, 0, 0.04);
    color: #27272a;
    box-shadow: 2px 2px rgba(0, 0, 0, 0.1);
  }
  :global(html.light) .external-link:hover {
    background-color: rgba(0, 0, 0, 0.08);
    box-shadow: 4px 4px #2563eb;
  }

  .external-link__icon {
    display: inline-block;
    vertical-align: middle;
    margin-right: 6px;
  }

  .external-link__header {
    margin: 0.2rem 0;
    color: rgb(27, 27, 27);
    font-size: 0.8rem;
  }

  :global(html.light) .external-link__header {
    color: #52525b;
  }

  /* Theme toggle button */
  #links-theme-toggle {
    position: fixed;
    bottom: 1.5rem;
    right: 1.5rem;
    z-index: 50;
    padding: 0.625rem;
    border-radius: 50%;
    border: 1px solid rgba(255, 255, 255, 0.15);
    background: rgba(255, 255, 255, 0.08);
    color: rgba(255, 255, 255, 0.6);
    cursor: pointer;
    transition: all 0.3s ease;
    backdrop-filter: blur(8px);
  }
  #links-theme-toggle:hover {
    color: white;
    border-color: rgba(255, 255, 255, 0.3);
    background: rgba(255, 255, 255, 0.15);
  }

  :global(html.light) #links-theme-toggle {
    border-color: rgba(0, 0, 0, 0.15);
    background: rgba(0, 0, 0, 0.05);
    color: rgba(0, 0, 0, 0.5);
  }
  :global(html.light) #links-theme-toggle:hover {
    color: #18181b;
    border-color: rgba(0, 0, 0, 0.25);
    background: rgba(0, 0, 0, 0.1);
  }

  /* Typed.js styles */
  :global(.typed_wrap) {
    height: auto;
    text-align: center;
    font-size: 1rem;
    display: block;
    position: relative;
    left: 50%;
    transform: translate(-50%, -50%);
    color: rgb(185, 185, 185);
    transition: color 0.3s ease;
  }

  :global(html.light .typed_wrap) {
    color: #71717a;
  }

  :global(.typed_wrap h1) {
    display: inline;
    font-size: 1.4rem;
  }
  :global(.typed::after) {
    content: "|";
    display: inline;
    animation: blink 0.7s infinite;
  }
  :global(.typed-cursor) {
    opacity: 0;
    display: none;
  }

  @keyframes blink {
    0% {
      opacity: 1;
    }
    50% {
      opacity: 0;
    }
    100% {
      opacity: 1;
    }
  }

  /* Responsive */
  @media screen and (min-width: 600px) {
    .main {
      width: 60%;
      margin: 0 auto;
    }
    .some-icons-container {
      justify-content: center;
    }
    .some-link {
      margin: 0.4rem;
    }
  }

  @media screen and (min-width: 1100px) {
    .main {
      width: 40%;
      margin: 0 auto;
      padding: 20px;
    }
  }
</style>

<script>
  const themeBtn = document.getElementById("links-theme-toggle");
  const darkIcon = themeBtn?.querySelector(".dark-icon");
  const lightIcon = themeBtn?.querySelector(".light-icon");

  function updateIcons() {
    const isLight = document.documentElement.classList.contains("light");
    if (darkIcon) (darkIcon as HTMLElement).style.display = isLight ? "none" : "block";
    if (lightIcon) (lightIcon as HTMLElement).style.display = isLight ? "block" : "none";
  }

  updateIcons();

  themeBtn?.addEventListener("click", () => {
    const isLight = document.documentElement.classList.contains("light");
    document.documentElement.classList.toggle("light", !isLight);
    document.documentElement.classList.toggle("dark", isLight);
    localStorage.setItem("theme", isLight ? "dark" : "light");
    updateIcons();
  });
</script>
