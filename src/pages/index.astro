---
import BaseLayout from "../components/layout/BaseLayout.astro";
import Navigation from "../components/layout/Navigation.astro";
import Footer from "../components/layout/Footer.astro";
import IdentityStrip from "../components/hub/IdentityStrip.astro";
import BlogCard from "../components/hub/BlogCard.astro";
import CvCard from "../components/hub/CvCard.astro";
import LabCard from "../components/hub/LabCard.astro";
import ProjectsCard from "../components/hub/ProjectsCard.astro";
import ArtCard from "../components/hub/ArtCard.astro";
import ContactCard from "../components/hub/ContactCard.astro";
import { siteData } from "../data/site-data";
---

<BaseLayout title="Artemio Padilla — Deep Learning Architect">
  <Navigation currentPath="/" />

  <main class="relative">
    <!-- Full-page grid backdrop -->
    <div class="page-grid pointer-events-none fixed inset-0 z-0"></div>
    <!-- Mouse-interactive grid glow (spotlight near cursor) -->
    <div class="grid-glow pointer-events-none fixed inset-0 z-0"></div>
    <!-- Soft glow orb that follows cursor -->
    <div class="cursor-glow pointer-events-none z-0"></div>

    <!-- Identity -->
    <IdentityStrip
      name={siteData.hero.name}
      title={siteData.hero.title}
      tagline={siteData.hero.tagline}
      highlights={siteData.hero.highlights}
      email={siteData.contact.email}
      linkedin={siteData.contact.linkedin}
      github={siteData.contact.github}
    />

    <!-- Card grid — flows directly from identity strip -->
    <section class="relative z-10 px-6 pb-24 md:pb-32">
      <div class="mx-auto max-w-5xl">
        <div class="hub-grid grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
          <div style="animation-delay: 80ms;"><BlogCard /></div>
          <div style="animation-delay: 140ms;"><CvCard /></div>
          <div style="animation-delay: 200ms;"><LabCard /></div>
          <div style="animation-delay: 260ms;"><ProjectsCard /></div>
          <div style="animation-delay: 320ms;"><ArtCard /></div>
          <div style="animation-delay: 380ms;"><ContactCard
            email={siteData.contact.email}
          /></div>
        </div>
      </div>
    </section>
  </main>

  <Footer />
</BaseLayout>

<style>
  .page-grid {
    position: fixed;
    background-image:
      linear-gradient(rgba(79, 143, 247, 0.03) 1px, transparent 1px),
      linear-gradient(90deg, rgba(79, 143, 247, 0.03) 1px, transparent 1px);
    background-size: 80px 80px;
    mask-image: linear-gradient(to bottom, transparent 5%, black 15%, black 75%, transparent 95%);
    -webkit-mask-image: linear-gradient(to bottom, transparent 5%, black 15%, black 75%, transparent 95%);
  }

  :global(html.light) .page-grid {
    background-image:
      linear-gradient(rgba(37, 99, 235, 0.035) 1px, transparent 1px),
      linear-gradient(90deg, rgba(37, 99, 235, 0.035) 1px, transparent 1px);
  }

  .hub-grid > div {
    display: flex;
    animation: hub-card-in 0.7s cubic-bezier(0.22, 1, 0.36, 1) both;
  }

  .hub-grid > div > :global(:first-child) {
    flex: 1;
  }

  @keyframes hub-card-in {
    from {
      opacity: 0;
      transform: translateY(24px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  /* ── Mouse-interactive grid spotlight ── */
  .grid-glow {
    position: fixed;
    background-image:
      linear-gradient(rgba(79, 143, 247, 0.35) 1px, transparent 1px),
      linear-gradient(90deg, rgba(79, 143, 247, 0.35) 1px, transparent 1px);
    background-size: 80px 80px;
    mask-image: radial-gradient(circle 400px at var(--mx, -500px) var(--my, -500px), black 0%, transparent 70%);
    -webkit-mask-image: radial-gradient(circle 400px at var(--mx, -500px) var(--my, -500px), black 0%, transparent 70%);
    opacity: 0;
    transition: opacity 0.3s ease;
  }

  :global(html.light) .grid-glow {
    background-image:
      linear-gradient(rgba(37, 99, 235, 0.25) 1px, transparent 1px),
      linear-gradient(90deg, rgba(37, 99, 235, 0.25) 1px, transparent 1px);
  }

  /* ── Cursor glow orb ── */
  .cursor-glow {
    width: 500px;
    height: 500px;
    border-radius: 50%;
    background: radial-gradient(circle, rgba(79, 143, 247, 0.08) 0%, transparent 70%);
    transform: translate(-50%, -50%);
    position: fixed;
    left: var(--mx, -500px);
    top: var(--my, -500px);
    opacity: 0;
    transition: opacity 0.3s ease;
  }

  :global(html.light) .cursor-glow {
    background: radial-gradient(circle, rgba(37, 99, 235, 0.06) 0%, transparent 70%);
  }
</style>

<script>
  const glow = document.querySelector('.grid-glow') as HTMLElement;
  const orb = document.querySelector('.cursor-glow') as HTMLElement;
  if (glow) {
    glow.style.opacity = '1';
    if (orb) orb.style.opacity = '1';
    document.addEventListener('mousemove', (e) => {
      requestAnimationFrame(() => {
        const x = e.clientX + 'px';
        const y = e.clientY + 'px';
        glow.style.setProperty('--mx', x);
        glow.style.setProperty('--my', y);
        if (orb) {
          orb.style.setProperty('--mx', x);
          orb.style.setProperty('--my', y);
        }
      });
    }, { passive: true });
    // Hide on touch devices
    document.addEventListener('touchstart', () => {
      glow.style.opacity = '0';
      if (orb) orb.style.opacity = '0';
    }, { once: true, passive: true });
  }
</script>
