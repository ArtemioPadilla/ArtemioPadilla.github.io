---
import BaseLayout from "../components/layout/BaseLayout.astro";
import Navigation from "../components/layout/Navigation.astro";
import Footer from "../components/layout/Footer.astro";
import IdentityStrip from "../components/hub/IdentityStrip.astro";
import BlogCard from "../components/hub/BlogCard.astro";
import CvCard from "../components/hub/CvCard.astro";
import LabCard from "../components/hub/LabCard.astro";
import ProjectsCard from "../components/hub/ProjectsCard.astro";
import ArtCard from "../components/hub/ArtCard.astro";
import ContactCard from "../components/hub/ContactCard.astro";
import { siteData } from "../data/site-data";
---

<BaseLayout title="Artemio Padilla — Deep Learning Architect">
  <Navigation currentPath="/" />

  <main class="relative">
    <!-- Full-page grid backdrop (extends behind everything) -->
    <div class="page-grid pointer-events-none fixed inset-0 z-0"></div>

    <!-- Identity -->
    <IdentityStrip
      name={siteData.hero.name}
      title={siteData.hero.title}
      tagline={siteData.hero.tagline}
      highlights={siteData.hero.highlights}
      email={siteData.contact.email}
      linkedin={siteData.contact.linkedin}
      github={siteData.contact.github}
    />

    <!-- Dashboard -->
    <section class="relative z-10 px-6 pb-20 md:pb-28">
      <div class="mx-auto max-w-5xl">
        <!-- Section label -->
        <div class="section-label mb-8 flex items-center gap-3">
          <div class="h-[2px] w-8 rounded-full bg-[var(--color-primary)]"></div>
          <span class="text-[10px] font-semibold tracking-[0.3em] text-[var(--color-primary)] uppercase">
            Dashboard
          </span>
          <div class="h-[1px] flex-1 bg-gradient-to-r from-[var(--color-border)] to-transparent"></div>
        </div>

        <!-- Card grid -->
        <div class="hub-grid grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
          <div style="animation-delay: 80ms;"><BlogCard /></div>
          <div style="animation-delay: 140ms;"><CvCard /></div>
          <div style="animation-delay: 200ms;"><LabCard /></div>
          <div style="animation-delay: 260ms;"><ProjectsCard /></div>
          <div style="animation-delay: 320ms;"><ArtCard /></div>
          <div style="animation-delay: 380ms;"><ContactCard
            email={siteData.contact.email}
            linkedin={siteData.contact.linkedin}
            github={siteData.contact.github}
          /></div>
        </div>
      </div>
    </section>
  </main>

  <Footer />
</BaseLayout>

<style>
  /* Subtle full-page grid — ties the whole page together */
  .page-grid {
    background-image:
      linear-gradient(rgba(79, 143, 247, 0.025) 1px, transparent 1px),
      linear-gradient(90deg, rgba(79, 143, 247, 0.025) 1px, transparent 1px);
    background-size: 80px 80px;
    mask-image: linear-gradient(to bottom, transparent, black 10%, black 80%, transparent);
    -webkit-mask-image: linear-gradient(to bottom, transparent, black 10%, black 80%, transparent);
  }

  :global(html.light) .page-grid {
    background-image:
      linear-gradient(rgba(37, 99, 235, 0.03) 1px, transparent 1px),
      linear-gradient(90deg, rgba(37, 99, 235, 0.03) 1px, transparent 1px);
  }

  /* Section label entrance */
  .section-label {
    animation: label-in 0.8s cubic-bezier(0.22, 1, 0.36, 1) 0.5s both;
  }

  @keyframes label-in {
    from {
      opacity: 0;
      transform: translateX(-12px);
    }
    to {
      opacity: 1;
      transform: translateX(0);
    }
  }

  /* Staggered card entrance */
  .hub-grid > div {
    animation: hub-card-in 0.7s cubic-bezier(0.22, 1, 0.36, 1) both;
  }

  @keyframes hub-card-in {
    from {
      opacity: 0;
      transform: translateY(24px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }
</style>
