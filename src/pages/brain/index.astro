---
import BaseLayout from "../../components/layout/BaseLayout.astro";
import Navigation from "../../components/layout/Navigation.astro";
import BrainApp from "../../components/brain/BrainApp";
import { loadAndValidateGraph } from "../../utils/graph-loader";

const graph = loadAndValidateGraph();
---

<BaseLayout
  title="Brain — Artemio Padilla"
  description="An interactive knowledge graph mapping ideas across science, philosophy, technology, and more."
>
  <Navigation currentPath="/brain" />

  <main class="brain-page">
    <BrainApp
      client:only="preact"
      nodes={graph.nodes}
      edges={graph.edges}
    />
  </main>
</BaseLayout>

<style>
  .brain-page {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    overflow: hidden;
  }
</style>

<style is:global>
  /* === Brain Container === */
  .brain-container {
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    overflow: hidden;
  }

  /* === Graph Controls === */
  .graph-controls {
    position: absolute;
    top: 72px;
    left: 16px;
    right: 16px;
    z-index: 20;
    display: flex;
    align-items: flex-start;
    gap: 8px;
    pointer-events: none;
  }

  .graph-controls > * {
    pointer-events: auto;
  }

  /* Search */
  .graph-search-container {
    position: relative;
    flex: 1;
    max-width: 400px;
  }

  .graph-search-wrapper {
    position: relative;
    display: flex;
    align-items: center;
  }

  .graph-search-icon {
    position: absolute;
    left: 12px;
    color: var(--color-text-muted);
  }

  .graph-search-input {
    width: 100%;
    padding: 10px 36px 10px 38px;
    border-radius: 12px;
    border: 1px solid var(--color-border);
    background: var(--color-surface);
    color: var(--color-text);
    font-size: 14px;
    font-family: Inter, sans-serif;
    outline: none;
    transition: all 0.2s;
    backdrop-filter: blur(12px);
  }

  html:not(.light) .graph-search-input {
    background: rgba(17, 17, 17, 0.85);
  }

  .graph-search-input:focus {
    border-color: var(--color-primary);
    box-shadow: 0 0 0 3px rgba(79, 143, 247, 0.15);
  }

  .graph-search-input::placeholder {
    color: var(--color-text-muted);
    opacity: 0.6;
  }

  .graph-search-clear {
    position: absolute;
    right: 8px;
    padding: 4px 8px;
    border: none;
    background: none;
    color: var(--color-text-muted);
    font-size: 18px;
    cursor: pointer;
    line-height: 1;
  }

  .graph-search-clear:hover {
    color: var(--color-heading);
  }

  .graph-search-results {
    position: absolute;
    top: 100%;
    left: 0;
    right: 0;
    margin-top: 4px;
    border-radius: 12px;
    border: 1px solid var(--color-border);
    background: var(--color-surface);
    overflow: hidden;
    z-index: 30;
    box-shadow: 0 8px 32px rgba(0, 0, 0, 0.3);
  }

  html:not(.light) .graph-search-results {
    background: rgba(17, 17, 17, 0.95);
    backdrop-filter: blur(12px);
  }

  .graph-search-result {
    display: flex;
    align-items: center;
    gap: 10px;
    width: 100%;
    padding: 10px 14px;
    border: none;
    background: none;
    color: var(--color-text);
    cursor: pointer;
    text-align: left;
    font-size: 14px;
    transition: background 0.15s;
  }

  .graph-search-result:hover {
    background: rgba(79, 143, 247, 0.1);
  }

  .graph-search-result-dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    flex-shrink: 0;
  }

  .graph-search-result-text {
    flex: 1;
    display: flex;
    flex-direction: column;
    min-width: 0;
  }

  .graph-search-result-label {
    font-weight: 500;
    color: var(--color-heading);
  }

  .graph-search-result-path {
    font-size: 11px;
    color: var(--color-text-muted);
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  .graph-search-result-type {
    font-size: 11px;
    color: var(--color-text-muted);
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  /* Layout selector */
  .graph-layout-selector {
    display: flex;
    border-radius: 10px;
    overflow: hidden;
    border: 1px solid var(--color-border);
    background: var(--color-surface);
    backdrop-filter: blur(12px);
  }

  html:not(.light) .graph-layout-selector {
    background: rgba(17, 17, 17, 0.85);
  }

  .graph-layout-btn {
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 10px 12px;
    border: none;
    background: none;
    color: var(--color-text-muted);
    cursor: pointer;
    transition: all 0.2s;
  }

  .graph-layout-btn.active {
    color: var(--color-heading);
    background: rgba(79, 143, 247, 0.15);
  }

  .graph-layout-btn:hover:not(.active) {
    color: var(--color-heading);
  }

  .graph-layout-btn svg {
    display: block;
  }

  /* Radial center badge */
  .graph-radial-badge {
    padding: 6px 12px;
    border-radius: 10px;
    border: 1px solid var(--color-border);
    background: var(--color-surface);
    backdrop-filter: blur(12px);
    font-size: 11px;
    color: var(--color-text-muted);
    white-space: nowrap;
  }

  html:not(.light) .graph-radial-badge {
    background: rgba(17, 17, 17, 0.85);
  }

  /* Relation filter count */
  .graph-filter-count {
    margin-left: auto;
    font-size: 11px;
    color: var(--color-text-muted);
    opacity: 0.6;
  }

  .graph-filter-option input[type="radio"] {
    accent-color: var(--color-primary);
  }

  /* View toggle */
  .graph-view-toggle {
    display: flex;
    border-radius: 10px;
    overflow: hidden;
    border: 1px solid var(--color-border);
    background: var(--color-surface);
    backdrop-filter: blur(12px);
  }

  html:not(.light) .graph-view-toggle {
    background: rgba(17, 17, 17, 0.85);
  }

  .graph-view-btn {
    padding: 10px 16px;
    border: none;
    background: none;
    color: var(--color-text-muted);
    font-size: 13px;
    font-weight: 600;
    font-family: Inter, sans-serif;
    cursor: pointer;
    transition: all 0.2s;
  }

  .graph-view-btn.active {
    color: var(--color-heading);
    background: rgba(79, 143, 247, 0.15);
  }

  .graph-view-btn:hover:not(.active) {
    color: var(--color-heading);
  }

  /* Filter */
  .graph-filter-container {
    position: relative;
  }

  .graph-filter-btn {
    display: flex;
    align-items: center;
    gap: 4px;
    padding: 10px 14px;
    border-radius: 10px;
    border: 1px solid var(--color-border);
    background: var(--color-surface);
    color: var(--color-text-muted);
    cursor: pointer;
    transition: all 0.2s;
    backdrop-filter: blur(12px);
  }

  html:not(.light) .graph-filter-btn {
    background: rgba(17, 17, 17, 0.85);
  }

  .graph-filter-btn.active {
    border-color: var(--color-primary);
    color: var(--color-primary);
  }

  .graph-filter-btn:hover {
    color: var(--color-heading);
    border-color: var(--color-text-muted);
  }

  .graph-filter-badge {
    background: var(--color-primary);
    color: white;
    font-size: 10px;
    font-weight: 700;
    padding: 1px 5px;
    border-radius: 6px;
    line-height: 1.4;
  }

  .graph-filter-dropdown {
    position: absolute;
    top: 100%;
    right: 0;
    margin-top: 4px;
    min-width: 200px;
    border-radius: 12px;
    border: 1px solid var(--color-border);
    background: var(--color-surface);
    padding: 8px;
    z-index: 30;
    box-shadow: 0 8px 32px rgba(0, 0, 0, 0.3);
  }

  html:not(.light) .graph-filter-dropdown {
    background: rgba(17, 17, 17, 0.95);
    backdrop-filter: blur(12px);
  }

  .graph-filter-section {
    padding: 4px 0;
  }

  .graph-filter-section-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    font-size: 11px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--color-text-muted);
    padding: 4px 8px;
  }

  .graph-filter-clear {
    border: none;
    background: none;
    color: var(--color-primary);
    font-size: 11px;
    cursor: pointer;
    padding: 0;
  }

  .graph-filter-divider {
    height: 1px;
    background: var(--color-border);
    margin: 4px 0;
  }

  .graph-filter-option {
    display: flex;
    align-items: center;
    gap: 8px;
    padding: 6px 8px;
    border-radius: 6px;
    cursor: pointer;
    transition: background 0.15s;
    font-size: 13px;
    color: var(--color-text);
  }

  .graph-filter-option:hover {
    background: rgba(79, 143, 247, 0.1);
  }

  .graph-filter-option input[type="checkbox"] {
    accent-color: var(--color-primary);
  }

  .graph-filter-dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
  }

  .graph-filter-label {
    text-transform: capitalize;
  }

  /* Legend */
  .graph-legend {
    position: absolute;
    bottom: 16px;
    left: 16px;
    display: flex;
    flex-wrap: wrap;
    gap: 12px;
    padding: 10px 14px;
    border-radius: 10px;
    border: 1px solid var(--color-border);
    background: var(--color-surface);
    backdrop-filter: blur(12px);
    z-index: 20;
  }

  html:not(.light) .graph-legend {
    background: rgba(17, 17, 17, 0.85);
  }

  .graph-legend-item {
    display: flex;
    align-items: center;
    gap: 6px;
  }

  .graph-legend-dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
  }

  .graph-legend-label {
    font-size: 11px;
    color: var(--color-text-muted);
    text-transform: capitalize;
  }

  /* Keyboard hints */
  .graph-hints {
    position: absolute;
    bottom: 16px;
    right: 16px;
    display: flex;
    gap: 12px;
    padding: 8px 12px;
    border-radius: 10px;
    border: 1px solid var(--color-border);
    background: var(--color-surface);
    backdrop-filter: blur(12px);
    z-index: 20;
    font-size: 11px;
    color: var(--color-text-muted);
  }

  html:not(.light) .graph-hints {
    background: rgba(17, 17, 17, 0.85);
  }

  .graph-hints kbd {
    display: inline-block;
    padding: 1px 5px;
    border-radius: 4px;
    border: 1px solid var(--color-border);
    background: var(--color-bg);
    font-family: monospace;
    font-size: 11px;
    color: var(--color-text);
  }

  /* Stats */
  .brain-stats {
    position: absolute;
    top: 72px;
    right: 16px;
    padding: 6px 12px;
    border-radius: 8px;
    font-size: 11px;
    color: var(--color-text-muted);
    z-index: 10;
    pointer-events: none;
  }

  /* === Detail Panel === */
  .detail-panel {
    position: absolute;
    top: 60px;
    right: 0;
    bottom: 0;
    width: 380px;
    max-width: 90vw;
    background: var(--color-surface);
    border-left: 1px solid var(--color-border);
    overflow-y: auto;
    z-index: 25;
    padding: 20px;
    animation: slideInRight 0.3s ease;
    backdrop-filter: blur(16px);
  }

  html:not(.light) .detail-panel {
    background: rgba(17, 17, 17, 0.95);
  }

  @keyframes slideInRight {
    from {
      transform: translateX(100%);
      opacity: 0;
    }
    to {
      transform: translateX(0);
      opacity: 1;
    }
  }

  .detail-panel-header {
    margin-bottom: 16px;
  }

  .detail-panel-close {
    float: right;
    padding: 6px;
    border: none;
    background: none;
    color: var(--color-text-muted);
    cursor: pointer;
    border-radius: 6px;
    transition: all 0.2s;
  }

  .detail-panel-close:hover {
    color: var(--color-heading);
    background: rgba(255, 255, 255, 0.05);
  }

  .detail-breadcrumb {
    font-size: 12px;
    color: var(--color-text-muted);
    margin-bottom: 8px;
  }

  .detail-breadcrumb-sep {
    margin: 0 4px;
    opacity: 0.5;
  }

  .detail-breadcrumb-link {
    border: none;
    background: none;
    color: var(--color-text-muted);
    cursor: pointer;
    padding: 0;
    font-size: 12px;
    text-transform: capitalize;
  }

  .detail-breadcrumb-link:hover {
    color: var(--color-primary);
  }

  .detail-title {
    font-family: "Saira Extra Condensed", sans-serif;
    font-size: 28px;
    font-weight: 700;
    line-height: 1.1;
    margin: 0;
  }

  .detail-badges {
    display: flex;
    gap: 6px;
    margin-top: 8px;
    flex-wrap: wrap;
  }

  .detail-badge {
    font-size: 11px;
    padding: 2px 8px;
    border-radius: 6px;
    border: 1px solid;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .detail-badge-muted {
    border-color: var(--color-border);
    color: var(--color-text-muted);
  }

  .detail-summary {
    font-size: 14px;
    line-height: 1.6;
    color: var(--color-text);
    margin: 16px 0;
    padding: 12px;
    border-radius: 8px;
    background: rgba(79, 143, 247, 0.05);
    border-left: 3px solid var(--domain-color, var(--color-primary));
  }

  .detail-content {
    font-size: 13px;
    line-height: 1.7;
    color: var(--color-text-muted);
    margin: 16px 0;
  }

  .detail-content p {
    margin-bottom: 10px;
  }

  .detail-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 6px;
    margin: 16px 0;
  }

  .detail-tag {
    font-size: 11px;
    padding: 3px 8px;
    border-radius: 6px;
    background: rgba(79, 143, 247, 0.08);
    color: var(--color-primary);
  }

  .detail-connections {
    margin: 20px 0;
  }

  .detail-connections-title {
    font-size: 12px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--color-text-muted);
    margin-bottom: 10px;
  }

  .detail-connection-group {
    margin-bottom: 12px;
  }

  .detail-relation-label {
    display: block;
    font-size: 11px;
    color: var(--color-text-muted);
    opacity: 0.7;
    margin-bottom: 4px;
    text-transform: capitalize;
  }

  .detail-connection-node {
    display: flex;
    align-items: center;
    gap: 8px;
    width: 100%;
    padding: 8px 10px;
    border: none;
    background: none;
    border-radius: 6px;
    cursor: pointer;
    transition: background 0.15s;
    text-align: left;
  }

  .detail-connection-node:hover {
    background: rgba(79, 143, 247, 0.1);
  }

  .detail-connection-dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    flex-shrink: 0;
  }

  .detail-connection-label {
    flex: 1;
    font-size: 13px;
    color: var(--color-heading);
  }

  .detail-connection-arrow {
    font-size: 12px;
    color: var(--color-text-muted);
    opacity: 0.5;
  }

  .detail-links {
    margin: 20px 0;
  }

  .detail-ext-link {
    display: flex;
    align-items: center;
    gap: 6px;
    font-size: 13px;
    color: var(--color-primary);
    text-decoration: none;
    padding: 6px 0;
  }

  .detail-ext-link:hover {
    text-decoration: underline;
  }

  .detail-fullpage-link {
    display: block;
    margin-top: 20px;
    padding: 10px 16px;
    border-radius: 8px;
    border: 1px solid var(--color-border);
    text-align: center;
    font-size: 13px;
    font-weight: 500;
    color: var(--color-heading);
    text-decoration: none;
    transition: all 0.2s;
  }

  .detail-fullpage-link:hover {
    border-color: var(--color-primary);
    background: rgba(79, 143, 247, 0.1);
    color: var(--color-primary);
  }

  .detail-meta {
    margin-top: 16px;
    font-size: 11px;
    color: var(--color-text-muted);
    opacity: 0.6;
  }

  /* === Mobile Responsive === */
  @media (max-width: 768px) {
    .graph-controls {
      top: 68px;
      left: 8px;
      right: 8px;
      flex-wrap: wrap;
    }

    .graph-search-container {
      max-width: none;
      order: 1;
      flex-basis: 100%;
    }

    .graph-layout-selector {
      order: 2;
    }

    .graph-view-toggle {
      order: 3;
    }

    .graph-filter-container {
      order: 4;
    }

    .graph-radial-badge {
      order: 5;
      font-size: 10px;
    }

    .brain-stats {
      display: none;
    }

    /* Panel becomes bottom drawer on mobile */
    .detail-panel {
      top: auto;
      right: 0;
      bottom: 0;
      left: 0;
      width: 100%;
      max-width: 100%;
      max-height: 60vh;
      border-left: none;
      border-top: 1px solid var(--color-border);
      border-radius: 16px 16px 0 0;
      animation: slideInBottom 0.3s ease;
    }

    @keyframes slideInBottom {
      from {
        transform: translateY(100%);
        opacity: 0;
      }
      to {
        transform: translateY(0);
        opacity: 1;
      }
    }

    .graph-legend {
      bottom: 8px;
      left: 8px;
      gap: 8px;
      padding: 8px 10px;
    }

    .graph-hints {
      display: none;
    }
  }

  /* Sigma container styling */
  .brain-container .sigma-container {
    width: 100% !important;
    height: 100% !important;
  }

  /* Hide scrollbar in detail panel */
  .detail-panel::-webkit-scrollbar {
    width: 4px;
  }

  .detail-panel::-webkit-scrollbar-track {
    background: transparent;
  }

  .detail-panel::-webkit-scrollbar-thumb {
    background: var(--color-border);
    border-radius: 2px;
  }
</style>
