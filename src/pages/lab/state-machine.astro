---
import BaseLayout from "../../components/layout/BaseLayout.astro";
import Navigation from "../../components/layout/Navigation.astro";
import Footer from "../../components/layout/Footer.astro";
import StateMachineDesigner from "../../components/lab/state-machine/StateMachine.tsx";
---

<BaseLayout
  title="State Machine Designer — Lab — Artemio Padilla"
  description="Draw finite automata, test input strings, and see DFA/NFA execution step by step. Build and visualize state machines interactively."
>
  <Navigation currentPath="/lab" />

  <main class="px-6 pt-32 pb-24 md:pt-40 md:pb-32">
    <div class="mx-auto max-w-6xl">
      <!-- Breadcrumb -->
      <div class="mb-6 flex items-center gap-2 text-xs text-[var(--color-text-muted)]">
        <a href="/lab" class="no-underline transition-colors hover:text-[var(--color-heading)]">Lab</a>
        <span>/</span>
        <span class="text-[var(--color-heading)]">State Machine Designer</span>
      </div>

      <!-- Header -->
      <div class="mb-8">
        <div class="flex items-center gap-3">
          <span class="text-3xl">&#8859;</span>
          <h1 class="font-heading text-3xl font-bold uppercase text-[var(--color-heading)] sm:text-4xl">
            State Machine Designer
          </h1>
        </div>
        <p class="mt-3 max-w-xl text-sm leading-relaxed text-[var(--color-text-muted)] sm:text-base">
          Draw finite automata interactively. Test input strings step by step, view the transition table, and detect DFA vs NFA. Supports epsilon transitions and NFA-to-DFA conversion.
        </p>
      </div>

      <!-- Tool -->
      <StateMachineDesigner client:visible />

      <!-- Info -->
      <div class="mt-6 text-xs text-[var(--color-text-muted)]">
        <p>All computation runs in your browser. No data is sent to any server. Click to add states, Shift+drag to connect them, right-click to toggle accept states.</p>
      </div>
    </div>
  </main>

  <Footer />
</BaseLayout>
