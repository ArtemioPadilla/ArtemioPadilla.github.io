---
import BaseLayout from "../../components/layout/BaseLayout.astro";
import Navigation from "../../components/layout/Navigation.astro";
import Footer from "../../components/layout/Footer.astro";
import McmcVisualizer from "../../components/lab/mcmc-visualizer/McmcVisualizer.tsx";
---

<BaseLayout
  title="MCMC Visualizer — Lab — Artemio Padilla"
  description="Watch Metropolis-Hastings and HMC sample from 2D distributions. See trace plots, diagnostics, and convergence in real-time."
>
  <Navigation currentPath="/lab" />

  <main class="px-6 pt-32 pb-24 md:pt-40 md:pb-32">
    <div class="mx-auto max-w-6xl">
      <!-- Breadcrumb -->
      <div class="mb-6 flex items-center gap-2 text-xs text-[var(--color-text-muted)]">
        <a href="/lab" class="no-underline transition-colors hover:text-[var(--color-heading)]">Lab</a>
        <span>/</span>
        <span class="text-[var(--color-heading)]">MCMC Visualizer</span>
      </div>

      <!-- Header -->
      <div class="mb-8">
        <div class="flex items-center gap-3">
          <span class="text-3xl">⟳</span>
          <h1 class="font-heading text-3xl font-bold uppercase text-[var(--color-heading)] sm:text-4xl">
            MCMC Visualizer
          </h1>
        </div>
        <p class="mt-3 max-w-xl text-sm leading-relaxed text-[var(--color-text-muted)] sm:text-base">
          Watch Metropolis-Hastings and Hamiltonian Monte Carlo explore 2D probability distributions. See trace plots, autocorrelation, acceptance rates, and effective sample sizes update in real-time.
        </p>
      </div>

      <!-- Tool -->
      <McmcVisualizer client:visible />

      <!-- Info -->
      <div class="mt-6 text-xs text-[var(--color-text-muted)]">
        <p>Implements Metropolis-Hastings and HMC from scratch. All computation runs in your browser.</p>
      </div>
    </div>
  </main>

  <Footer />
</BaseLayout>
