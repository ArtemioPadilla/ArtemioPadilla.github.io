---
import BaseLayout from "../../components/layout/BaseLayout.astro";
import Navigation from "../../components/layout/Navigation.astro";
import Footer from "../../components/layout/Footer.astro";
import LabToolLayout from "../../components/lab/LabToolLayout.astro";
import StrangeAttractors from "../../components/lab/strange-attractors/StrangeAttractors.tsx";
---

<BaseLayout
  title="Strange Attractors — Lab — Artemio Padilla"
  description="Visualize chaotic systems: Lorenz attractor, Rossler, double pendulum, bifurcation diagrams. 3D trajectories with Lyapunov exponents."
>
  <Navigation currentPath="/lab" />
  <LabToolLayout currentSlug="strange-attractors">
  <main class="px-6 pt-32 pb-24 md:pt-40 md:pb-32">
    <div class="mx-auto max-w-5xl">
      <!-- Breadcrumb -->
      <div class="mb-6 flex items-center gap-2 text-xs text-[var(--color-text-muted)]">
        <a href="/lab" class="no-underline transition-colors hover:text-[var(--color-heading)]">Lab</a>
        <span>/</span>
        <span class="text-[var(--color-heading)]">Strange Attractors</span>
      </div>

      <!-- Header -->
      <div class="mb-8">
        <div class="flex items-center gap-3">
          <span class="text-3xl">&#8734;</span>
          <h1 class="font-heading text-3xl font-bold uppercase text-[var(--color-heading)] sm:text-4xl">
            Strange Attractors
          </h1>
        </div>
        <p class="mt-3 max-w-xl text-sm leading-relaxed text-[var(--color-text-muted)] sm:text-base">
          Explore chaos theory through interactive visualizations. Lorenz and Rossler attractors in 3D, double pendulum with sensitive dependence, Henon map, and logistic map bifurcation diagrams.
        </p>
      </div>

      <!-- Tool -->
      <StrangeAttractors client:visible />

      <!-- Info -->
      <div class="mt-6 text-xs text-[var(--color-text-muted)]">
        <p>All computations run entirely in your browser using RK4 integration for ODE systems. Drag to rotate 3D views. Scroll to zoom. Click the bifurcation diagram to select an r value.</p>
      </div>
    </div>
  </main>

  <Footer />
  </LabToolLayout>
</BaseLayout>
