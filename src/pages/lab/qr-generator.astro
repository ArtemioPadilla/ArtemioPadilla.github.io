---
import BaseLayout from "../../components/layout/BaseLayout.astro";
import Navigation from "../../components/layout/Navigation.astro";
import Footer from "../../components/layout/Footer.astro";
import QrGenerator from "../../components/lab/qr-generator/QrGenerator.tsx";
---

<BaseLayout
  title="QR Code Generator — Lab — Artemio Padilla"
  description="Generate QR codes for text, URLs, WiFi, and vCards. Customize colors, size, and error correction. Download as PNG or SVG."
>
  <Navigation currentPath="/lab" />

  <main class="px-6 pt-32 pb-24 md:pt-40 md:pb-32">
    <div class="mx-auto max-w-5xl">
      <!-- Breadcrumb -->
      <div class="mb-6 flex items-center gap-2 text-xs text-[var(--color-text-muted)]">
        <a href="/lab" class="no-underline transition-colors hover:text-[var(--color-heading)]">Lab</a>
        <span>/</span>
        <span class="text-[var(--color-heading)]">QR Code Generator</span>
      </div>

      <!-- Header -->
      <div class="mb-8">
        <div class="flex items-center gap-3">
          <span class="text-3xl">⬚</span>
          <h1 class="font-heading text-3xl font-bold uppercase text-[var(--color-heading)] sm:text-4xl">
            QR Code Generator
          </h1>
        </div>
        <p class="mt-3 max-w-xl text-sm leading-relaxed text-[var(--color-text-muted)] sm:text-base">
          Generate QR codes for text, URLs, WiFi credentials, or contact cards. Customize colors, shape, and error correction level. Download as PNG or SVG.
        </p>
      </div>

      <!-- Tool -->
      <QrGenerator client:visible />

      <!-- Info -->
      <div class="mt-6 text-xs text-[var(--color-text-muted)]">
        <p>QR encoding implemented from scratch — your data never leaves your browser. Supports byte mode, versions 1-10, and all error correction levels.</p>
      </div>
    </div>
  </main>

  <Footer />
</BaseLayout>
