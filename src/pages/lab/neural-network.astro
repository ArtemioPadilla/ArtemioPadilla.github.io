---
import BaseLayout from "../../components/layout/BaseLayout.astro";
import Navigation from "../../components/layout/Navigation.astro";
import Footer from "../../components/layout/Footer.astro";
import NeuralNetworkPlayground from "../../components/lab/neural-network/NeuralNetworkPlayground.tsx";
---

<BaseLayout
  title="Neural Network Playground — Lab — Artemio Padilla"
  description="Build and train small neural networks on toy 2D datasets. Watch decision boundaries evolve in real-time."
>
  <Navigation currentPath="/lab" />

  <main class="px-6 pt-32 pb-24 md:pt-40 md:pb-32">
    <div class="mx-auto max-w-5xl">
      <!-- Breadcrumb -->
      <div class="mb-6 flex items-center gap-2 text-xs text-[var(--color-text-muted)]">
        <a href="/lab" class="no-underline transition-colors hover:text-[var(--color-heading)]">Lab</a>
        <span>/</span>
        <span class="text-[var(--color-heading)]">Neural Network Playground</span>
      </div>

      <!-- Header -->
      <div class="mb-8">
        <div class="flex items-center gap-3">
          <span class="text-3xl">&#129504;</span>
          <h1 class="font-heading text-3xl font-bold uppercase text-[var(--color-heading)] sm:text-4xl">
            Neural Network Playground
          </h1>
        </div>
        <p class="mt-3 max-w-xl text-sm leading-relaxed text-[var(--color-text-muted)] sm:text-base">
          Build and train small neural networks on toy 2D datasets. Watch decision boundaries evolve in real-time.
        </p>
      </div>

      <!-- Tool -->
      <NeuralNetworkPlayground client:visible />

      <!-- Info -->
      <div class="mt-6 text-xs text-[var(--color-text-muted)]">
        <p>
          Inspired by <a href="https://playground.tensorflow.org/" target="_blank" rel="noopener noreferrer" class="underline hover:text-[var(--color-heading)]">TensorFlow Playground</a>.
          Neural network implemented from scratch — no ML libraries. All training runs entirely in your browser.
        </p>
      </div>
    </div>
  </main>

  <Footer />
</BaseLayout>
