---
import BaseLayout from "../../components/layout/BaseLayout.astro";
import Navigation from "../../components/layout/Navigation.astro";
import Footer from "../../components/layout/Footer.astro";
import LabToolLayout from "../../components/lab/LabToolLayout.astro";
import SqlPlayground from "../../components/lab/sql-playground/SqlPlayground.tsx";
---

<BaseLayout
  title="SQL Playground — Lab — Artemio Padilla"
  description="Write and execute SQL queries in the browser. SQLite via WebAssembly with preset databases, schema viewer, and query history."
>
  <Navigation currentPath="/lab" />
  <LabToolLayout currentSlug="sql-playground">
  <main class="px-6 pt-32 pb-24 md:pt-40 md:pb-32">
    <div class="mx-auto max-w-6xl">
      <!-- Breadcrumb -->
      <div class="mb-6 flex items-center gap-2 text-xs text-[var(--color-text-muted)]">
        <a href="/lab" class="no-underline transition-colors hover:text-[var(--color-heading)]">Lab</a>
        <span>/</span>
        <span class="text-[var(--color-heading)]">SQL Playground</span>
      </div>

      <!-- Header -->
      <div class="mb-8">
        <div class="flex items-center gap-3">
          <span class="text-3xl">&#128451;</span>
          <h1 class="font-heading text-3xl font-bold uppercase text-[var(--color-heading)] sm:text-4xl">
            SQL Playground
          </h1>
        </div>
        <p class="mt-3 max-w-xl text-sm leading-relaxed text-[var(--color-text-muted)] sm:text-base">
          Write and execute SQL queries in the browser. Explore preset databases, view schemas, and export results.
        </p>
      </div>

      <!-- Tool -->
      <SqlPlayground client:visible />

      <!-- Info -->
      <div class="mt-6 text-xs text-[var(--color-text-muted)]">
        <p>
          Powered by <a href="https://sql.js.org" target="_blank" rel="noopener noreferrer" class="text-[var(--color-primary)] hover:underline">sql.js</a> (SQLite compiled to WebAssembly). Everything runs in your browser — no data is sent to any server.
        </p>
      </div>
    </div>
  </main>

  <Footer />
  </LabToolLayout>
</BaseLayout>
