---
import BaseLayout from "../../components/layout/BaseLayout.astro";
import Navigation from "../../components/layout/Navigation.astro";
import Footer from "../../components/layout/Footer.astro";
import LabToolLayout from "../../components/lab/LabToolLayout.astro";
import HashGenerator from "../../components/lab/hash-generator/HashGenerator.tsx";
---

<BaseLayout
  title="Hash Generator — Lab — Artemio Padilla"
  description="Generate MD5, SHA-1, SHA-256, SHA-512, and CRC32 hashes for text or files. Compare hashes and compute HMACs."
>
  <Navigation currentPath="/lab" />
  <LabToolLayout currentSlug="hash-generator">
  <main class="px-6 pt-32 pb-24 md:pt-40 md:pb-32">
    <div class="mx-auto max-w-5xl">
      <!-- Breadcrumb -->
      <div class="mb-6 flex items-center gap-2 text-xs text-[var(--color-text-muted)]">
        <a href="/lab" class="no-underline transition-colors hover:text-[var(--color-heading)]">Lab</a>
        <span>/</span>
        <span class="text-[var(--color-heading)]">Hash Generator</span>
      </div>

      <!-- Header -->
      <div class="mb-8">
        <div class="flex items-center gap-3">
          <span class="text-3xl font-bold" style="font-family: var(--font-mono); color: var(--color-primary);">#</span>
          <h1 class="font-heading text-3xl font-bold uppercase text-[var(--color-heading)] sm:text-4xl">
            Hash Generator
          </h1>
        </div>
        <p class="mt-3 max-w-xl text-sm leading-relaxed text-[var(--color-text-muted)] sm:text-base">
          Generate MD5, SHA-1, SHA-256, SHA-384, SHA-512, and CRC32 hashes for text or files. Compare, compute HMACs, and export in multiple formats.
        </p>
      </div>

      <!-- Tool -->
      <HashGenerator client:visible />

      <!-- Info -->
      <div class="mt-6 text-xs text-[var(--color-text-muted)]">
        <p>Uses Web Crypto API for SHA family. MD5 and CRC32 implemented from scratch. Nothing leaves your browser.</p>
      </div>
    </div>
  </main>

  <Footer />
  </LabToolLayout>
</BaseLayout>
