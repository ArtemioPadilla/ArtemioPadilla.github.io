---
import BaseLayout from "../../components/layout/BaseLayout.astro";
import Navigation from "../../components/layout/Navigation.astro";
import Footer from "../../components/layout/Footer.astro";
import LabToolLayout from "../../components/lab/LabToolLayout.astro";
import CellularAutomata from "../../components/lab/cellular-automata/CellularAutomata.tsx";
---

<BaseLayout
  title="Cellular Automata — Lab — Artemio Padilla"
  description="Conway's Game of Life and Wolfram's elementary rules. Draw patterns, adjust rules, and watch emergence unfold."
>
  <Navigation currentPath="/lab" />
  <LabToolLayout currentSlug="cellular-automata">
  <main class="px-6 pt-32 pb-24 md:pt-40 md:pb-32">
    <div class="mx-auto max-w-6xl">
      <!-- Breadcrumb -->
      <div class="mb-6 flex items-center gap-2 text-xs text-[var(--color-text-muted)]">
        <a href="/lab" class="no-underline transition-colors hover:text-[var(--color-heading)]">Lab</a>
        <span>/</span>
        <span class="text-[var(--color-heading)]">Cellular Automata</span>
      </div>

      <!-- Header -->
      <div class="mb-8">
        <div class="flex items-center gap-3">
          <span class="text-3xl">⬡</span>
          <h1 class="font-heading text-3xl font-bold uppercase text-[var(--color-heading)] sm:text-4xl">
            Cellular Automata
          </h1>
        </div>
        <p class="mt-3 max-w-xl text-sm leading-relaxed text-[var(--color-text-muted)] sm:text-base">
          Conway's Game of Life with custom birth/survival rules, Wolfram's 256 elementary automata, preset patterns, drawing tools, and multiple color modes.
        </p>
      </div>

      <!-- Tool -->
      <CellularAutomata client:visible />

      <!-- Info -->
      <div class="mt-6 text-xs text-[var(--color-text-muted)]">
        <p>
          Click to draw cells, use scroll to zoom, shift+drag to pan. All simulation runs entirely in your browser.
        </p>
      </div>
    </div>
  </main>

  <Footer />
  </LabToolLayout>
</BaseLayout>
