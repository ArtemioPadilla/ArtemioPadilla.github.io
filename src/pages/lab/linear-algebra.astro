---
import BaseLayout from "../../components/layout/BaseLayout.astro";
import Navigation from "../../components/layout/Navigation.astro";
import Footer from "../../components/layout/Footer.astro";
import LabToolLayout from "../../components/lab/LabToolLayout.astro";
import LinearAlgebra from "../../components/lab/linear-algebra/LinearAlgebra.tsx";
---

<BaseLayout
  title="Linear Algebra — Lab — Artemio Padilla"
  description="Visualize 2D matrix transformations. See rotation, scaling, shearing, eigenvalues, and grid deformation in real-time."
>
  <Navigation currentPath="/lab" />
  <LabToolLayout currentSlug="linear-algebra">
  <main class="px-6 pt-32 pb-24 md:pt-40 md:pb-32">
    <div class="mx-auto max-w-6xl">
      <!-- Breadcrumb -->
      <div class="mb-6 flex items-center gap-2 text-xs text-[var(--color-text-muted)]">
        <a href="/lab" class="no-underline transition-colors hover:text-[var(--color-heading)]">Lab</a>
        <span>/</span>
        <span class="text-[var(--color-heading)]">Linear Algebra</span>
      </div>

      <!-- Header -->
      <div class="mb-8">
        <div class="flex items-center gap-3">
          <span class="text-3xl font-mono">&#x27E6;&#x27E7;</span>
          <h1 class="font-heading text-3xl font-bold uppercase text-[var(--color-heading)] sm:text-4xl">
            Linear Algebra
          </h1>
        </div>
        <p class="mt-3 max-w-xl text-sm leading-relaxed text-[var(--color-text-muted)] sm:text-base">
          Visualize 2D matrix transformations. Edit matrices and watch vectors, shapes, and grid lines transform in real-time.
        </p>
      </div>

      <!-- Tool -->
      <LinearAlgebra client:visible />

      <!-- Info -->
      <div class="mt-6 text-xs text-[var(--color-text-muted)]">
        <p>
          Inspired by <a href="https://www.3blue1brown.com/topics/linear-algebra" target="_blank" rel="noopener noreferrer" class="underline hover:text-[var(--color-primary)]">3Blue1Brown's Essence of Linear Algebra</a>.
          All computation runs entirely in your browser.
        </p>
      </div>
    </div>
  </main>

  <Footer />
  </LabToolLayout>
</BaseLayout>
