---
import BaseLayout from "../../components/layout/BaseLayout.astro";
import Navigation from "../../components/layout/Navigation.astro";
import Footer from "../../components/layout/Footer.astro";
import LabToolLayout from "../../components/lab/LabToolLayout.astro";
import FourierViz from "../../components/lab/fourier-viz/FourierViz.tsx";
---

<BaseLayout
  title="Fourier Transform — Lab — Artemio Padilla"
  description="Draw a signal and see its frequency decomposition. Watch epicycles reconstruct waveforms."
>
  <Navigation currentPath="/lab" />
  <LabToolLayout currentSlug="fourier-viz">
  <main class="px-6 pt-32 pb-24 md:pt-40 md:pb-32">
    <div class="mx-auto max-w-5xl">
      <!-- Breadcrumb -->
      <div class="mb-6 flex items-center gap-2 text-xs text-[var(--color-text-muted)]">
        <a href="/lab" class="no-underline transition-colors hover:text-[var(--color-heading)]">Lab</a>
        <span>/</span>
        <span class="text-[var(--color-heading)]">Fourier Transform</span>
      </div>

      <!-- Header -->
      <div class="mb-8">
        <div class="flex items-center gap-3">
          <span class="text-3xl font-mono">~</span>
          <h1 class="font-heading text-3xl font-bold uppercase text-[var(--color-heading)] sm:text-4xl">
            Fourier Transform
          </h1>
        </div>
        <p class="mt-3 max-w-xl text-sm leading-relaxed text-[var(--color-text-muted)] sm:text-base">
          Draw a signal and watch it decompose into frequencies. See epicycles reconstruct waveforms one harmonic at a time.
        </p>
      </div>

      <!-- Tool -->
      <FourierViz client:visible />

      <!-- Info -->
      <div class="mt-6 text-xs text-[var(--color-text-muted)]">
        <p>
          Draw on the canvas or select a preset. All computation runs entirely in your browser.
        </p>
      </div>
    </div>
  </main>

  <Footer />
  </LabToolLayout>
</BaseLayout>
