---
import BaseLayout from "../../components/layout/BaseLayout.astro";
import Navigation from "../../components/layout/Navigation.astro";
import Footer from "../../components/layout/Footer.astro";
import LabToolLayout from "../../components/lab/LabToolLayout.astro";
import ClusteringViz from "../../components/lab/clustering/ClusteringViz.tsx";
---

<BaseLayout
  title="Clustering Visualizer — Lab — Artemio Padilla"
  description="Place points and watch K-Means, DBSCAN, and hierarchical clustering algorithms group them step by step."
>
  <Navigation currentPath="/lab" />
  <LabToolLayout currentSlug="clustering">
  <main class="px-6 pt-32 pb-24 md:pt-40 md:pb-32">
    <div class="mx-auto max-w-5xl">
      <!-- Breadcrumb -->
      <div class="mb-6 flex items-center gap-2 text-xs text-[var(--color-text-muted)]">
        <a href="/lab" class="no-underline transition-colors hover:text-[var(--color-heading)]">Lab</a>
        <span>/</span>
        <span class="text-[var(--color-heading)]">Clustering Visualizer</span>
      </div>

      <!-- Header -->
      <div class="mb-8">
        <div class="flex items-center gap-3">
          <span class="text-3xl">&#129767;</span>
          <h1 class="font-heading text-3xl font-bold uppercase text-[var(--color-heading)] sm:text-4xl">
            Clustering Visualizer
          </h1>
        </div>
        <p class="mt-3 max-w-xl text-sm leading-relaxed text-[var(--color-text-muted)] sm:text-base">
          Place points and watch K-Means, DBSCAN, Hierarchical, and Mean Shift clustering algorithms group them step by step.
        </p>
      </div>

      <!-- Tool -->
      <ClusteringViz client:visible />

      <!-- Info -->
      <div class="mt-6 text-xs text-[var(--color-text-muted)]">
        <p>All algorithms run entirely in your browser. No data is sent anywhere.</p>
      </div>
    </div>
  </main>

  <Footer />
  </LabToolLayout>
</BaseLayout>
