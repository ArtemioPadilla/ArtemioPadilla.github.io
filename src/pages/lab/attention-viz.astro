---
import BaseLayout from "../../components/layout/BaseLayout.astro";
import Navigation from "../../components/layout/Navigation.astro";
import Footer from "../../components/layout/Footer.astro";
import LabToolLayout from "../../components/lab/LabToolLayout.astro";
import AttentionViz from "../../components/lab/attention-viz/AttentionViz.tsx";
---

<BaseLayout
  title="Transformer Attention Visualizer — Lab — Artemio Padilla"
  description="Visualize self-attention, multi-head attention, and positional encoding in transformers. Type text and see attention heatmaps update live."
>
  <Navigation currentPath="/lab" />
  <LabToolLayout currentSlug="attention-viz">
  <main class="px-6 pt-32 pb-24 md:pt-40 md:pb-32">
    <div class="mx-auto max-w-6xl">
      <!-- Breadcrumb -->
      <div class="mb-6 flex items-center gap-2 text-xs text-[var(--color-text-muted)]">
        <a href="/lab" class="no-underline transition-colors hover:text-[var(--color-heading)]">Lab</a>
        <span>/</span>
        <span class="text-[var(--color-heading)]">Transformer Attention Visualizer</span>
      </div>

      <!-- Header -->
      <div class="mb-8">
        <div class="flex items-center gap-3">
          <span class="text-3xl">&#128065;</span>
          <h1 class="font-heading text-3xl font-bold uppercase text-[var(--color-heading)] sm:text-4xl">
            Transformer Attention Visualizer
          </h1>
        </div>
        <p class="mt-3 max-w-xl text-sm leading-relaxed text-[var(--color-text-muted)] sm:text-base">
          Visualize self-attention, multi-head attention, and positional encoding in transformers. Type text and see attention heatmaps update live.
        </p>
      </div>

      <!-- Tool -->
      <AttentionViz client:visible />

      <!-- Info -->
      <div class="mt-6 text-xs text-[var(--color-text-muted)]">
        <p>
          All attention computations run from scratch in your browser — no ML libraries or external APIs. Random Q, K, V weight matrices are generated on load; click "Randomize Weights" to resample.
        </p>
      </div>
    </div>
  </main>

  <Footer />
  </LabToolLayout>
</BaseLayout>
