---
import BaseLayout from "../../components/layout/BaseLayout.astro";
import Navigation from "../../components/layout/Navigation.astro";
import Footer from "../../components/layout/Footer.astro";
import LabToolLayout from "../../components/lab/LabToolLayout.astro";
import NetworkProtocols from "../../components/lab/network-protocols/NetworkProtocols.tsx";
---

<BaseLayout
  title="Network Protocol Visualizer — Lab — Artemio Padilla"
  description="Animated TCP handshakes, HTTP request flows, DNS resolution, and TLS negotiation. Step through network protocols visually."
>
  <Navigation currentPath="/lab" />
  <LabToolLayout currentSlug="network-protocols">
  <main class="px-6 pt-32 pb-24 md:pt-40 md:pb-32">
    <div class="mx-auto max-w-6xl">
      <!-- Breadcrumb -->
      <div class="mb-6 flex items-center gap-2 text-xs text-[var(--color-text-muted)]">
        <a href="/lab" class="no-underline transition-colors hover:text-[var(--color-heading)]">Lab</a>
        <span>/</span>
        <span class="text-[var(--color-heading)]">Network Protocol Visualizer</span>
      </div>

      <!-- Header -->
      <div class="mb-8">
        <div class="flex items-center gap-3">
          <span class="text-3xl">🌐</span>
          <h1 class="font-heading text-3xl font-bold uppercase text-[var(--color-heading)] sm:text-4xl">
            Network Protocol Visualizer
          </h1>
        </div>
        <p class="mt-3 max-w-xl text-sm leading-relaxed text-[var(--color-text-muted)] sm:text-base">
          Step through animated sequence diagrams of TCP, HTTP, DNS, TLS, and UDP. Inspect packet headers and see which OSI layers are active at each step.
        </p>
      </div>

      <!-- Tool -->
      <NetworkProtocols client:visible />

      <!-- Info -->
      <div class="mt-6 text-xs text-[var(--color-text-muted)]">
        <p>
          Use arrow keys or the step controls to navigate. Click any arrow in the diagram to inspect its packet headers. All visualization runs entirely in your browser.
        </p>
      </div>
    </div>
  </main>

  <Footer />
  </LabToolLayout>
</BaseLayout>
