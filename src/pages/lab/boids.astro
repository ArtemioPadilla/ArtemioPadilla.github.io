---
import BaseLayout from "../../components/layout/BaseLayout.astro";
import Navigation from "../../components/layout/Navigation.astro";
import Footer from "../../components/layout/Footer.astro";
import LabToolLayout from "../../components/lab/LabToolLayout.astro";
import Boids from "../../components/lab/boids/Boids.tsx";
---

<BaseLayout
  title="Boids Flocking — Lab — Artemio Padilla"
  description="Craig Reynolds' flocking simulation with separation, alignment, and cohesion. Add predators, obstacles, and wind. Watch emergent swarm behavior."
>
  <Navigation currentPath="/lab" />
  <LabToolLayout currentSlug="boids">
  <main class="px-6 pt-32 pb-24 md:pt-40 md:pb-32">
    <div class="mx-auto max-w-6xl">
      <!-- Breadcrumb -->
      <div class="mb-6 flex items-center gap-2 text-xs text-[var(--color-text-muted)]">
        <a href="/lab" class="no-underline transition-colors hover:text-[var(--color-heading)]">Lab</a>
        <span>/</span>
        <span class="text-[var(--color-heading)]">Boids Flocking</span>
      </div>

      <!-- Header -->
      <div class="mb-8">
        <div class="flex items-center gap-3">
          <span class="text-3xl">🐦</span>
          <h1 class="font-heading text-3xl font-bold uppercase text-[var(--color-heading)] sm:text-4xl">
            Boids Flocking
          </h1>
        </div>
        <p class="mt-3 max-w-xl text-sm leading-relaxed text-[var(--color-text-muted)] sm:text-base">
          Craig Reynolds' flocking algorithm: separation, alignment, and cohesion. Click to add predators, right-click for obstacles, drag to create wind.
        </p>
      </div>

      <!-- Tool -->
      <Boids client:visible />

      <!-- Info -->
      <div class="mt-6 text-xs text-[var(--color-text-muted)]">
        <p>
          Click to add a predator (red triangle). Right-click to place obstacles. Drag to create wind force. All simulation runs entirely in your browser.
        </p>
      </div>
    </div>
  </main>

  <Footer />
  </LabToolLayout>
</BaseLayout>
