---
import BaseLayout from "../../components/layout/BaseLayout.astro";
import Navigation from "../../components/layout/Navigation.astro";
import Footer from "../../components/layout/Footer.astro";
import LabToolLayout from "../../components/lab/LabToolLayout.astro";
import BlockchainViz from "../../components/lab/blockchain/BlockchainViz.tsx";
---

<BaseLayout
  title="Blockchain Visualizer — Lab — Artemio Padilla"
  description="Mine blocks, see hash chaining, and detect tampering. Interactive proof-of-work demonstration with adjustable difficulty."
>
  <Navigation currentPath="/lab" />
  <LabToolLayout currentSlug="blockchain">
  <main class="px-6 pt-32 pb-24 md:pt-40 md:pb-32">
    <div class="mx-auto max-w-6xl">
      <!-- Breadcrumb -->
      <div class="mb-6 flex items-center gap-2 text-xs text-[var(--color-text-muted)]">
        <a href="/lab" class="no-underline transition-colors hover:text-[var(--color-heading)]">Lab</a>
        <span>/</span>
        <span class="text-[var(--color-heading)]">Blockchain Visualizer</span>
      </div>

      <!-- Header -->
      <div class="mb-8">
        <div class="flex items-center gap-3">
          <span class="text-3xl">⛓</span>
          <h1 class="font-heading text-3xl font-bold uppercase text-[var(--color-heading)] sm:text-4xl">
            Blockchain Visualizer
          </h1>
        </div>
        <p class="mt-3 max-w-xl text-sm leading-relaxed text-[var(--color-text-muted)] sm:text-base">
          Mine blocks, tamper with data, and see the chain break. An interactive proof-of-work demonstration with Merkle trees and peer consensus.
        </p>
      </div>

      <!-- Tool -->
      <BlockchainViz client:visible />

      <!-- Info -->
      <div class="mt-6 text-xs text-[var(--color-text-muted)]">
        <p>
          Edit a block's data to see the tamper-detection cascade. Adjust difficulty to control mining time. All hashing uses SHA-256 via Web Crypto API, entirely in your browser.
        </p>
      </div>
    </div>
  </main>

  <Footer />
  </LabToolLayout>
</BaseLayout>
