---
import BaseLayout from "../../components/layout/BaseLayout.astro";
import Navigation from "../../components/layout/Navigation.astro";
import Footer from "../../components/layout/Footer.astro";
import TokenizerPlayground from "../../components/lab/tokenizer/TokenizerPlayground.tsx";
---

<BaseLayout
  title="Tokenizer Playground — Lab — Artemio Padilla"
  description="Visualize how LLM tokenizers break text into tokens. See BPE merges step-by-step and compare token counts."
>
  <Navigation currentPath="/lab" />

  <main class="px-6 pt-32 pb-24 md:pt-40 md:pb-32">
    <div class="mx-auto max-w-5xl">
      <!-- Breadcrumb -->
      <div class="mb-6 flex items-center gap-2 text-xs text-[var(--color-text-muted)]">
        <a href="/lab" class="no-underline transition-colors hover:text-[var(--color-heading)]">Lab</a>
        <span>/</span>
        <span class="text-[var(--color-heading)]">Tokenizer Playground</span>
      </div>

      <!-- Header -->
      <div class="mb-8">
        <div class="flex items-center gap-3">
          <span class="text-3xl">🔤</span>
          <h1 class="font-heading text-3xl font-bold uppercase text-[var(--color-heading)] sm:text-4xl">
            Tokenizer Playground
          </h1>
        </div>
        <p class="mt-3 max-w-xl text-sm leading-relaxed text-[var(--color-text-muted)] sm:text-base">
          Visualize how LLM tokenizers break text into tokens. See BPE merges step-by-step and compare token counts across models.
        </p>
      </div>

      <!-- Tool -->
      <TokenizerPlayground client:visible />

      <!-- Info -->
      <div class="mt-6 text-xs text-[var(--color-text-muted)]">
        <p>
          Uses a simplified BPE implementation for demonstration. Token counts for specific models are heuristic estimates.
          All processing runs entirely in your browser — nothing is sent to a server.
        </p>
      </div>
    </div>
  </main>

  <Footer />
</BaseLayout>
