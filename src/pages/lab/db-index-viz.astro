---
import BaseLayout from "../../components/layout/BaseLayout.astro";
import Navigation from "../../components/layout/Navigation.astro";
import Footer from "../../components/layout/Footer.astro";
import LabToolLayout from "../../components/lab/LabToolLayout.astro";
import DBIndexViz from "../../components/lab/db-index-viz/DBIndexViz.tsx";
---

<BaseLayout
  title="Database Index Visualizer — Lab — Artemio Padilla"
  description="Visualize B-Tree, B+ Tree, and Hash Index operations. Watch insertions split nodes, deletions merge them, and searches traverse the tree."
>
  <Navigation currentPath="/lab" />
  <LabToolLayout currentSlug="db-index-viz">
  <main class="px-6 pt-32 pb-24 md:pt-40 md:pb-32">
    <div class="mx-auto max-w-6xl">
      <!-- Breadcrumb -->
      <div class="mb-6 flex items-center gap-2 text-xs text-[var(--color-text-muted)]">
        <a href="/lab" class="no-underline transition-colors hover:text-[var(--color-heading)]">Lab</a>
        <span>/</span>
        <span class="text-[var(--color-heading)]">Database Index Visualizer</span>
      </div>

      <!-- Header -->
      <div class="mb-8">
        <div class="flex items-center gap-3">
          <span class="text-3xl">&#128451;</span>
          <h1 class="font-heading text-3xl font-bold uppercase text-[var(--color-heading)] sm:text-4xl">
            Database Index Visualizer
          </h1>
        </div>
        <p class="mt-3 max-w-xl text-sm leading-relaxed text-[var(--color-text-muted)] sm:text-base">
          Visualize B-Tree, B+ Tree, and Hash Index operations. Watch insertions split nodes, deletions merge them, and searches traverse the tree step by step.
        </p>
      </div>

      <!-- Tool -->
      <DBIndexViz client:visible />

      <!-- Info -->
      <div class="mt-6 text-xs text-[var(--color-text-muted)]">
        <p>All operations run entirely in your browser. No data is sent anywhere.</p>
      </div>
    </div>
  </main>

  <Footer />
  </LabToolLayout>
</BaseLayout>
