---
import BaseLayout from "../../components/layout/BaseLayout.astro";
import Navigation from "../../components/layout/Navigation.astro";
import Footer from "../../components/layout/Footer.astro";
import LabToolLayout from "../../components/lab/LabToolLayout.astro";
import ColorPalette from "../../components/lab/color-palette/ColorPalette.tsx";
---

<BaseLayout
  title="Color Palette Generator — Lab — Artemio Padilla"
  description="Generate accessible color palettes with contrast checks and colorblind simulation."
>
  <Navigation currentPath="/lab" />
  <LabToolLayout currentSlug="color-palette">
  <main class="px-6 pt-32 pb-24 md:pt-40 md:pb-32">
    <div class="mx-auto max-w-5xl">
      <!-- Breadcrumb -->
      <div class="mb-6 flex items-center gap-2 text-xs text-[var(--color-text-muted)]">
        <a href="/lab" class="no-underline transition-colors hover:text-[var(--color-heading)]">Lab</a>
        <span>/</span>
        <span class="text-[var(--color-heading)]">Color Palette Generator</span>
      </div>

      <!-- Header -->
      <div class="mb-8">
        <div class="flex items-center gap-3">
          <span class="text-3xl">&#x1F3A8;</span>
          <h1 class="font-heading text-3xl font-bold uppercase text-[var(--color-heading)] sm:text-4xl">
            Color Palette Generator
          </h1>
        </div>
        <p class="mt-3 max-w-xl text-sm leading-relaxed text-[var(--color-text-muted)] sm:text-base">
          Generate accessible color palettes for data visualization. Check contrast ratios and simulate colorblind vision.
        </p>
      </div>

      <!-- Tool -->
      <ColorPalette client:visible />

      <!-- Info -->
      <div class="mt-6 text-xs text-[var(--color-text-muted)]">
        <p>All color computation runs entirely in your browser — nothing is sent to a server.</p>
      </div>
    </div>
  </main>

  <Footer />
  </LabToolLayout>
</BaseLayout>
