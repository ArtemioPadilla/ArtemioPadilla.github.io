---
import BaseLayout from "../../components/layout/BaseLayout.astro";
import Navigation from "../../components/layout/Navigation.astro";
import Footer from "../../components/layout/Footer.astro";
import JsonVisualizer from "../../components/lab/json-visualizer/JsonVisualizer.tsx";
---

<BaseLayout
  title="JSON Visualizer — Lab — Artemio Padilla"
  description="Explore JSON data with tree view, table view, syntax highlighting, JSONPath queries, and structure statistics."
>
  <Navigation currentPath="/lab" />

  <main class="px-6 pt-32 pb-24 md:pt-40 md:pb-32">
    <div class="mx-auto max-w-6xl">
      <div class="mb-6 flex items-center gap-2 text-xs text-[var(--color-text-muted)]">
        <a href="/lab" class="no-underline transition-colors hover:text-[var(--color-heading)]">Lab</a>
        <span>/</span>
        <span class="text-[var(--color-heading)]">JSON Visualizer</span>
      </div>

      <div class="mb-8">
        <div class="flex items-center gap-3">
          <span class="text-3xl">&#123;&#125;</span>
          <h1 class="font-heading text-3xl font-bold uppercase text-[var(--color-heading)] sm:text-4xl">
            JSON Visualizer
          </h1>
        </div>
        <p class="mt-3 max-w-xl text-sm leading-relaxed text-[var(--color-text-muted)] sm:text-base">
          Explore JSON with tree view, table view, syntax highlighting, and JSONPath queries.
        </p>
      </div>

      <JsonVisualizer client:visible />

      <div class="mt-6 text-xs text-[var(--color-text-muted)]">
        <p>Supports JSONPath queries, structure statistics, format/minify, and copy. Everything runs in your browser.</p>
      </div>
    </div>
  </main>

  <Footer />
</BaseLayout>
