---
import BaseLayout from "../../components/layout/BaseLayout.astro";
import Navigation from "../../components/layout/Navigation.astro";
import Footer from "../../components/layout/Footer.astro";
import ShaderPlayground from "../../components/lab/shader-playground/ShaderPlayground.tsx";
---

<BaseLayout
  title="Shader Playground — Lab — Artemio Padilla"
  description="Write GLSL fragment shaders with live WebGL preview. Create plasma, fire, fractals, and more with GPU-accelerated graphics."
>
  <Navigation currentPath="/lab" />

  <main class="px-6 pt-32 pb-24 md:pt-40 md:pb-32">
    <div class="mx-auto max-w-7xl">
      <!-- Breadcrumb -->
      <div class="mb-6 flex items-center gap-2 text-xs text-[var(--color-text-muted)]">
        <a href="/lab" class="no-underline transition-colors hover:text-[var(--color-heading)]">Lab</a>
        <span>/</span>
        <span class="text-[var(--color-heading)]">Shader Playground</span>
      </div>

      <!-- Header -->
      <div class="mb-8">
        <div class="flex items-center gap-3">
          <span class="text-3xl" style="color: var(--color-primary);">&#9670;</span>
          <h1 class="font-heading text-3xl font-bold uppercase text-[var(--color-heading)] sm:text-4xl">
            Shader Playground
          </h1>
        </div>
        <p class="mt-3 max-w-xl text-sm leading-relaxed text-[var(--color-text-muted)] sm:text-base">
          Write GLSL fragment shaders and see them render in real-time. Pick a preset or write your own from scratch.
        </p>
      </div>

      <!-- Tool -->
      <ShaderPlayground client:visible />

      <!-- Info -->
      <div class="mt-6 text-xs text-[var(--color-text-muted)]">
        <p>
          Everything runs on your GPU via WebGL 1.0 — nothing is sent to a server.
          Inspired by <a href="https://www.shadertoy.com" target="_blank" rel="noopener noreferrer" class="text-[var(--color-primary)] hover:underline">Shadertoy</a>.
        </p>
      </div>
    </div>
  </main>

  <Footer />
</BaseLayout>
