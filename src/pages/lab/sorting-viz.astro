---
import BaseLayout from "../../components/layout/BaseLayout.astro";
import Navigation from "../../components/layout/Navigation.astro";
import Footer from "../../components/layout/Footer.astro";
import LabToolLayout from "../../components/lab/LabToolLayout.astro";
import SortingViz from "../../components/lab/sorting-viz/SortingViz.tsx";
---

<BaseLayout
  title="Sorting Visualizer — Lab — Artemio Padilla"
  description="Watch sorting algorithms race with animated bar charts. Compare Bubble, Quick, Merge, Heap, and more side by side."
>
  <Navigation currentPath="/lab" />
  <LabToolLayout currentSlug="sorting-viz">
  <main class="px-6 pt-32 pb-24 md:pt-40 md:pb-32">
    <div class="mx-auto max-w-5xl">
      <!-- Breadcrumb -->
      <div class="mb-6 flex items-center gap-2 text-xs text-[var(--color-text-muted)]">
        <a href="/lab" class="no-underline transition-colors hover:text-[var(--color-heading)]">Lab</a>
        <span>/</span>
        <span class="text-[var(--color-heading)]">Sorting Visualizer</span>
      </div>

      <!-- Header -->
      <div class="mb-8">
        <div class="flex items-center gap-3">
          <span class="text-3xl">&#9637;</span>
          <h1 class="font-heading text-3xl font-bold uppercase text-[var(--color-heading)] sm:text-4xl">
            Sorting Visualizer
          </h1>
        </div>
        <p class="mt-3 max-w-xl text-sm leading-relaxed text-[var(--color-text-muted)] sm:text-base">
          Watch 10 sorting algorithms in action with animated bar charts. Race them side by side, adjust speed and array size, and hear the sort.
        </p>
      </div>

      <!-- Tool -->
      <SortingViz client:visible />

      <!-- Info -->
      <div class="mt-6 text-xs text-[var(--color-text-muted)]">
        <p>All algorithms run entirely in your browser. No data is sent anywhere.</p>
      </div>
    </div>
  </main>

  <Footer />
  </LabToolLayout>
</BaseLayout>
