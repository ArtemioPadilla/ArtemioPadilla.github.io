---
import BaseLayout from "../../components/layout/BaseLayout.astro";
import Navigation from "../../components/layout/Navigation.astro";
import Footer from "../../components/layout/Footer.astro";
import PixelArt from "../../components/lab/pixel-art/PixelArt.tsx";
---

<BaseLayout
  title="Pixel Art Editor — Lab — Artemio Padilla"
  description="Create pixel art with pencil, fill, line, and shape tools. Layers, animation frames, undo/redo, and PNG/GIF export."
>
  <Navigation currentPath="/lab" />

  <main class="px-6 pt-32 pb-24 md:pt-40 md:pb-32">
    <div class="mx-auto max-w-6xl">
      <!-- Breadcrumb -->
      <div class="mb-6 flex items-center gap-2 text-xs text-[var(--color-text-muted)]">
        <a href="/lab" class="no-underline transition-colors hover:text-[var(--color-heading)]">Lab</a>
        <span>/</span>
        <span class="text-[var(--color-heading)]">Pixel Art Editor</span>
      </div>

      <!-- Header -->
      <div class="mb-8">
        <div class="flex items-center gap-3">
          <span class="text-3xl">🎨</span>
          <h1 class="font-heading text-3xl font-bold uppercase text-[var(--color-heading)] sm:text-4xl">
            Pixel Art Editor
          </h1>
        </div>
        <p class="mt-3 max-w-xl text-sm leading-relaxed text-[var(--color-text-muted)] sm:text-base">
          Create pixel art with pencil, fill, line, and shape tools. Add layers, animate frames, and export as PNG or GIF.
        </p>
      </div>

      <!-- Tool -->
      <PixelArt client:visible />

      <!-- Info -->
      <div class="mt-6 text-xs text-[var(--color-text-muted)]">
        <p>All drawing and export runs entirely in your browser. Keyboard shortcuts: B=brush, E=eraser, G=fill, L=line, R=rectangle, C=circle, I=eyedropper, [/]=brush size, Ctrl+Z=undo, Ctrl+Shift+Z=redo.</p>
      </div>
    </div>
  </main>

  <Footer />
</BaseLayout>
