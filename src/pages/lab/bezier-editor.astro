---
import BaseLayout from "../../components/layout/BaseLayout.astro";
import Navigation from "../../components/layout/Navigation.astro";
import Footer from "../../components/layout/Footer.astro";
import LabToolLayout from "../../components/lab/LabToolLayout.astro";
import BezierEditor from "../../components/lab/bezier-editor/BezierEditor.tsx";
---

<BaseLayout
  title="Bezier Curve Editor — Lab — Artemio Padilla"
  description="Drag control points to shape Bezier curves. Watch de Casteljau's algorithm animate the construction step by step."
>
  <Navigation currentPath="/lab" />
  <LabToolLayout currentSlug="bezier-editor">
  <main class="px-6 pt-32 pb-24 md:pt-40 md:pb-32">
    <div class="mx-auto max-w-5xl">
      <!-- Breadcrumb -->
      <div class="mb-6 flex items-center gap-2 text-xs text-[var(--color-text-muted)]">
        <a href="/lab" class="no-underline transition-colors hover:text-[var(--color-heading)]">Lab</a>
        <span>/</span>
        <span class="text-[var(--color-heading)]">Bezier Curve Editor</span>
      </div>

      <!-- Header -->
      <div class="mb-8">
        <div class="flex items-center gap-3">
          <span class="text-3xl">⌒</span>
          <h1 class="font-heading text-3xl font-bold uppercase text-[var(--color-heading)] sm:text-4xl">
            Bezier Curve Editor
          </h1>
        </div>
        <p class="mt-3 max-w-xl text-sm leading-relaxed text-[var(--color-text-muted)] sm:text-base">
          Drag control points to shape Bezier curves. Animate de Casteljau's algorithm, chain curves with continuity, and export SVG paths.
        </p>
      </div>

      <!-- Tool -->
      <BezierEditor client:visible />

      <!-- Info -->
      <div class="mt-6 text-xs text-[var(--color-text-muted)]">
        <p>All computations run entirely in your browser. Drag control points to reshape curves. Use the t slider or animation to explore the de Casteljau construction.</p>
      </div>
    </div>
  </main>

  <Footer />
  </LabToolLayout>
</BaseLayout>
