---
import BaseLayout from "../../components/layout/BaseLayout.astro";
import Navigation from "../../components/layout/Navigation.astro";
import Footer from "../../components/layout/Footer.astro";
import MarkdownPreview from "../../components/lab/markdown-preview/MarkdownPreview.tsx";
---

<BaseLayout
  title="Markdown Previewer — Lab — Artemio Padilla"
  description="Live split-pane Markdown editor with from-scratch GFM parser supporting tables, task lists, code blocks, and more."
>
  <Navigation currentPath="/lab" />

  <main class="px-6 pt-32 pb-24 md:pt-40 md:pb-32">
    <div class="mx-auto max-w-6xl">
      <div class="mb-6 flex items-center gap-2 text-xs text-[var(--color-text-muted)]">
        <a href="/lab" class="no-underline transition-colors hover:text-[var(--color-heading)]">Lab</a>
        <span>/</span>
        <span class="text-[var(--color-heading)]">Markdown Previewer</span>
      </div>

      <div class="mb-8">
        <div class="flex items-center gap-3">
          <span class="text-3xl">&#9998;</span>
          <h1 class="font-heading text-3xl font-bold uppercase text-[var(--color-heading)] sm:text-4xl">
            Markdown Previewer
          </h1>
        </div>
        <p class="mt-3 max-w-xl text-sm leading-relaxed text-[var(--color-text-muted)] sm:text-base">
          Write Markdown with instant live preview. From-scratch GFM parser with tables, task lists, code blocks, and more.
        </p>
      </div>

      <MarkdownPreview client:visible />

      <div class="mt-6 text-xs text-[var(--color-text-muted)]">
        <p>Parser built from scratch. Supports headings, bold, italic, strikethrough, code blocks, tables, task lists, blockquotes, images, links, and horizontal rules.</p>
      </div>
    </div>
  </main>

  <Footer />
</BaseLayout>
