---
import BaseLayout from "../../components/layout/BaseLayout.astro";
import Navigation from "../../components/layout/Navigation.astro";
import Footer from "../../components/layout/Footer.astro";
import LabToolLayout from "../../components/lab/LabToolLayout.astro";
import MusicTheory from "../../components/lab/music-theory/MusicTheory.tsx";
---

<BaseLayout
  title="Music Theory Visualizer — Lab — Artemio Padilla"
  description="Interactive piano keyboard, circle of fifths, scales, and chord progressions with Web Audio playback."
>
  <Navigation currentPath="/lab" />
  <LabToolLayout currentSlug="music-theory">
  <main class="px-6 pt-32 pb-24 md:pt-40 md:pb-32">
    <div class="mx-auto max-w-5xl">
      <!-- Breadcrumb -->
      <div class="mb-6 flex items-center gap-2 text-xs text-[var(--color-text-muted)]">
        <a href="/lab" class="no-underline transition-colors hover:text-[var(--color-heading)]">Lab</a>
        <span>/</span>
        <span class="text-[var(--color-heading)]">Music Theory Visualizer</span>
      </div>

      <!-- Header -->
      <div class="mb-8">
        <div class="flex items-center gap-3">
          <span class="text-3xl">🎵</span>
          <h1 class="font-heading text-3xl font-bold uppercase text-[var(--color-heading)] sm:text-4xl">
            Music Theory Visualizer
          </h1>
        </div>
        <p class="mt-3 max-w-xl text-sm leading-relaxed text-[var(--color-text-muted)] sm:text-base">
          Interactive piano keyboard, circle of fifths, scales, and chord progressions with Web Audio playback.
          Explore intervals, diatonic chords, and common progressions.
        </p>
      </div>

      <!-- Tool -->
      <MusicTheory client:visible />

      <!-- Info -->
      <div class="mt-6 text-xs text-[var(--color-text-muted)]">
        <p>Uses Web Audio API for sound generation. All processing happens in your browser. Click notes on the piano keyboard to play them.</p>
      </div>
    </div>
  </main>

  <Footer />
  </LabToolLayout>
</BaseLayout>
