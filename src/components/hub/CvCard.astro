---
import { loadAndValidateCV } from "../../utils/cv-loader";
import HubCard from "./HubCard.astro";

const cv = loadAndValidateCV();
const currentJob = cv.experience.find((e) => e.current);
---

<HubCard title="CV" href="/cv" accentColor="var(--color-accent)">
  <svg slot="icon" class="h-5 w-5" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M15.75 6a3.75 3.75 0 11-7.5 0 3.75 3.75 0 017.5 0zM4.501 20.118a7.5 7.5 0 0114.998 0A17.933 17.933 0 0112 21.75c-2.676 0-5.216-.584-7.499-1.632z" /></svg>

  {currentJob ? (
    <div>
      <p class="text-sm text-[var(--color-heading)]">{currentJob.title}</p>
      <p class="mt-1 text-xs text-[var(--color-text-muted)]">{currentJob.company}</p>
    </div>
  ) : (
    <p class="text-sm text-[var(--color-text-muted)]">Full curriculum vitae</p>
  )}
  <p class="mt-auto pt-3 text-xs font-medium text-[var(--color-text-muted)]">
    {cv.experience.length} roles &middot; {cv.education.length} degrees
  </p>
</HubCard>
