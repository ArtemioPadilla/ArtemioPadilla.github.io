---
import { getCollection } from "astro:content";
import HubCard from "./HubCard.astro";

const allPosts = await getCollection("blog", ({ data }) => {
  return import.meta.env.PROD ? !data.draft : true;
});

const posts = allPosts.sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);

const latestPost = posts[0];
const postCount = posts.length;
---

<HubCard title="Blog" href="/blog" accentColor="var(--color-primary)">
  <svg slot="icon" class="h-5 w-5" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M12 7.5h1.5m-1.5 3h1.5m-7.5 3h7.5m-7.5 3h7.5m3-9h3.375c.621 0 1.125.504 1.125 1.125V18a2.25 2.25 0 01-2.25 2.25M16.5 7.5V18a2.25 2.25 0 002.25 2.25M16.5 7.5V4.875c0-.621-.504-1.125-1.125-1.125H4.125C3.504 3.75 3 4.254 3 4.875V18a2.25 2.25 0 002.25 2.25h13.5M6 7.5h3v3H6v-3z" /></svg>

  {latestPost ? (
    <div>
      <p class="text-sm leading-relaxed text-[var(--color-heading)]">
        {latestPost.data.title}
      </p>
      <p class="mt-1.5 text-xs text-[var(--color-text-muted)]">
        {latestPost.data.pubDate.toLocaleDateString("en-US", { month: "short", day: "numeric", year: "numeric" })}
      </p>
    </div>
  ) : (
    <p class="text-sm text-[var(--color-text-muted)]">Coming soon</p>
  )}
  <p class="mt-auto pt-3 text-xs font-medium text-[var(--color-text-muted)]">
    {postCount} {postCount === 1 ? "post" : "posts"}
  </p>
</HubCard>
