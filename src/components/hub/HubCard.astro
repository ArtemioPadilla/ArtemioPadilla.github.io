---
interface Props {
  title: string;
  href: string;
  accentColor?: string;
  external?: boolean;
}

const { title, href, accentColor = "var(--color-primary)", external = false } = Astro.props;
---

<a
  href={href}
  {...(external ? { target: "_blank", rel: "noopener noreferrer" } : {})}
  class="hub-card card-surface group relative flex min-h-[220px] flex-col overflow-hidden rounded-2xl no-underline transition-all duration-500"
  style={`--hub-accent: ${accentColor};`}
>
  <!-- Top accent stripe -->
  <div class="card-accent-stripe"></div>

  <!-- Background glow (always-on, intensifies on hover) -->
  <div class="card-bg-glow"></div>

  <!-- Gradient border -->
  <div class="card-gradient-border"></div>

  <div class="relative z-10 flex flex-1 flex-col p-6 sm:p-7">
    <!-- Icon + arrow row -->
    <div class="flex items-start justify-between">
      <div class="icon-frame flex h-10 w-10 items-center justify-center rounded-xl">
        <slot name="icon" />
      </div>
      <svg
        class="arrow-icon h-4 w-4"
        fill="none"
        stroke="currentColor"
        viewBox="0 0 24 24"
      >
        {external ? (
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
        ) : (
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 17L17 7M17 7H7M17 7v10" />
        )}
      </svg>
    </div>

    <!-- Title -->
    <h2 class="card-title mt-4 font-heading text-xl font-bold uppercase tracking-wide">
      {title}
    </h2>

    <!-- Slot content -->
    <div class="mt-2 flex flex-1 flex-col">
      <slot />
    </div>
  </div>
</a>

<style>
  .hub-card {
    border: 1px solid var(--color-border);
    background: var(--color-surface);
    position: relative;
  }

  /* ── Top accent stripe ── */
  .card-accent-stripe {
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 2px;
    background: linear-gradient(
      90deg,
      transparent 5%,
      var(--hub-accent) 50%,
      transparent 95%
    );
    opacity: 0.5;
    transition: opacity 0.4s ease;
  }

  .hub-card:hover .card-accent-stripe {
    opacity: 1;
  }

  /* ── Background glow (subtle always-on, stronger on hover) ── */
  .card-bg-glow {
    position: absolute;
    top: 0;
    left: 10%;
    right: 10%;
    height: 140px;
    background: radial-gradient(
      ellipse at 50% 0%,
      color-mix(in srgb, var(--hub-accent) 5%, transparent),
      transparent 80%
    );
    pointer-events: none;
    transition: all 0.5s ease;
  }

  .hub-card:hover .card-bg-glow {
    background: radial-gradient(
      ellipse at 50% 0%,
      color-mix(in srgb, var(--hub-accent) 12%, transparent),
      transparent 80%
    );
    height: 180px;
  }

  :global(html.light) .card-bg-glow {
    background: radial-gradient(
      ellipse at 50% 0%,
      color-mix(in srgb, var(--hub-accent) 3%, transparent),
      transparent 80%
    );
  }

  :global(html.light) .hub-card:hover .card-bg-glow {
    background: radial-gradient(
      ellipse at 50% 0%,
      color-mix(in srgb, var(--hub-accent) 6%, transparent),
      transparent 80%
    );
  }

  /* ── Gradient border ── */
  .card-gradient-border {
    position: absolute;
    inset: 0;
    border-radius: inherit;
    padding: 1px;
    background: linear-gradient(
      160deg,
      color-mix(in srgb, var(--hub-accent) 35%, transparent),
      transparent 35%,
      transparent 65%,
      color-mix(in srgb, var(--hub-accent) 15%, transparent)
    );
    -webkit-mask: linear-gradient(#fff 0 0) content-box, linear-gradient(#fff 0 0);
    -webkit-mask-composite: xor;
    mask-composite: exclude;
    pointer-events: none;
    opacity: 0;
    transition: opacity 0.5s ease;
  }

  .hub-card:hover .card-gradient-border {
    opacity: 1;
  }

  /* ── Icon frame ── */
  .icon-frame {
    border: 1px solid color-mix(in srgb, var(--hub-accent) 20%, var(--color-border));
    background: color-mix(in srgb, var(--hub-accent) 5%, var(--color-bg));
    color: var(--hub-accent);
    transition: all 0.4s ease;
  }

  .hub-card:hover .icon-frame {
    border-color: color-mix(in srgb, var(--hub-accent) 40%, transparent);
    background: color-mix(in srgb, var(--hub-accent) 10%, var(--color-bg));
    box-shadow: 0 0 16px color-mix(in srgb, var(--hub-accent) 15%, transparent);
  }

  /* ── Arrow ── */
  .arrow-icon {
    color: var(--color-text-muted);
    opacity: 0.3;
    transition: all 0.5s ease;
  }

  .hub-card:hover .arrow-icon {
    color: var(--hub-accent);
    opacity: 0.8;
    transform: translate(2px, -2px);
  }

  /* ── Title ── */
  .card-title {
    color: var(--color-heading);
    transition: color 0.3s ease;
  }
  .hub-card:hover .card-title {
    color: var(--hub-accent);
  }

  /* ── Hover lift ── */
  .hub-card:hover {
    border-color: color-mix(in srgb, var(--hub-accent) 25%, var(--color-border));
    transform: translateY(-3px);
    box-shadow:
      0 12px 40px color-mix(in srgb, var(--hub-accent) 8%, transparent),
      0 0 0 1px color-mix(in srgb, var(--hub-accent) 10%, transparent);
  }

  :global(html.light) .hub-card:hover {
    box-shadow:
      0 8px 24px rgba(0, 0, 0, 0.08),
      0 0 0 1px color-mix(in srgb, var(--hub-accent) 15%, transparent);
  }

  /* ── Entrance ── */
  .hub-card {
    animation: card-enter 0.7s cubic-bezier(0.22, 1, 0.36, 1) both;
  }

  @keyframes card-enter {
    from { opacity: 0; transform: translateY(20px); }
    to { opacity: 1; transform: translateY(0); }
  }
</style>
