---
import { fetchGitHubRepos } from "../../utils/github";
import HubCard from "./HubCard.astro";

const repos = await fetchGitHubRepos();
const repoCount = repos.length;

// Top languages
const langCounts = new Map<string, number>();
for (const repo of repos) {
  if (repo.language) {
    langCounts.set(repo.language, (langCounts.get(repo.language) || 0) + 1);
  }
}
const topLangs = [...langCounts.entries()]
  .sort((a, b) => b[1] - a[1])
  .slice(0, 3)
  .map(([lang]) => lang);
---

<HubCard title="Projects" href="/projects" accentColor="#a78bfa">
  <svg slot="icon" class="h-5 w-5" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M17.25 6.75L22.5 12l-5.25 5.25m-10.5 0L1.5 12l5.25-5.25m7.5-3l-4.5 16.5" /></svg>

  <div>
    <p class="text-sm text-[var(--color-text-muted)]">
      <span class="font-mono font-bold text-[var(--color-heading)]">{repoCount}</span> repositories
    </p>
    {topLangs.length > 0 && (
      <p class="mt-1.5 text-xs text-[var(--color-text-muted)]">
        {topLangs.join(" · ")}
      </p>
    )}
  </div>
  <p class="mt-auto pt-3 text-xs font-medium text-[var(--color-text-muted)]">
    Open source on GitHub
  </p>
</HubCard>
