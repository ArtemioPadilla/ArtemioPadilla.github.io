---
interface Props {
  name: string;
  title: string;
  tagline: string;
  highlights: { label: string; detail: string }[];
  email: string;
  linkedin: string;
  github: string;
}

const { name, title, tagline, highlights, email, linkedin, github } = Astro.props;
const [firstName, lastName] = [name.split(" ")[0], name.split(" ").slice(1).join(" ")];
---

<section class="relative overflow-hidden px-6 pt-28 pb-16 md:pt-36 md:pb-20">
  <div class="relative z-10 mx-auto max-w-5xl text-center">
    <!-- Name -->
    <h1 class="strip-animate font-heading leading-[0.85] font-bold uppercase tracking-tight">
      <span class="block text-5xl text-[var(--color-heading)] sm:text-6xl md:text-7xl">{firstName}</span>
      <span class="block text-4xl text-[var(--color-text-muted)] sm:text-5xl md:text-6xl">{lastName}</span>
    </h1>

    <!-- Title badge -->
    <div class="strip-animate mt-5">
      <span class="inline-block rounded-full border border-[var(--color-primary)]/30 bg-[var(--color-primary)]/10 px-4 py-1.5 text-xs font-semibold tracking-[0.2em] text-[var(--color-primary)] uppercase">
        {title}
      </span>
    </div>

    <!-- Tagline -->
    <p class="strip-animate mx-auto mt-5 max-w-xl text-sm leading-relaxed text-[var(--color-text-muted)] sm:text-base">
      {tagline}
    </p>

    <!-- Highlight badges -->
    <div class="strip-animate mt-6 flex flex-wrap items-center justify-center gap-2">
      {highlights.map((h) => (
        <span class="rounded-full border border-[var(--color-border)] px-3 py-1 text-xs font-medium text-[var(--color-text-muted)]">
          <span class="text-[var(--color-heading)]">{h.label}</span>
          <span class="mx-1 text-[var(--color-border)]">&middot;</span>
          {h.detail}
        </span>
      ))}
    </div>

    <!-- Social icons -->
    <div class="strip-animate mt-6 flex items-center justify-center gap-3">
      <a
        href={github}
        target="_blank"
        rel="noopener noreferrer"
        class="rounded-full border border-[var(--color-border)] p-2.5 text-[var(--color-text-muted)] transition-all duration-300 hover:border-[var(--color-primary)]/30 hover:text-[var(--color-heading)]"
        aria-label="GitHub"
      >
        <svg class="h-4 w-4" fill="currentColor" viewBox="0 0 24 24"><path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z" /></svg>
      </a>
      <a
        href={linkedin}
        target="_blank"
        rel="noopener noreferrer"
        class="rounded-full border border-[var(--color-border)] p-2.5 text-[var(--color-text-muted)] transition-all duration-300 hover:border-[var(--color-primary)]/30 hover:text-[var(--color-heading)]"
        aria-label="LinkedIn"
      >
        <svg class="h-4 w-4" fill="currentColor" viewBox="0 0 24 24"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z" /></svg>
      </a>
      <a
        href={`mailto:${email}`}
        class="rounded-full border border-[var(--color-border)] p-2.5 text-[var(--color-text-muted)] transition-all duration-300 hover:border-[var(--color-primary)]/30 hover:text-[var(--color-heading)]"
        aria-label="Email"
      >
        <svg class="h-4 w-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" /></svg>
      </a>
    </div>
  </div>
</section>

<style>
  .strip-animate {
    animation: strip-fade 0.8s cubic-bezier(0.22, 1, 0.36, 1) both;
  }

  .strip-animate:nth-child(1) { animation-delay: 0s; }
  .strip-animate:nth-child(2) { animation-delay: 0.1s; }
  .strip-animate:nth-child(3) { animation-delay: 0.2s; }
  .strip-animate:nth-child(4) { animation-delay: 0.3s; }
  .strip-animate:nth-child(5) { animation-delay: 0.4s; }

  @keyframes strip-fade {
    from { opacity: 0; transform: translateY(16px); }
    to { opacity: 1; transform: translateY(0); }
  }
</style>
