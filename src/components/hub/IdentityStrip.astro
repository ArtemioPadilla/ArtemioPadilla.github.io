---
interface Props {
  name: string;
  title: string;
  tagline: string;
  highlights: { label: string; detail: string }[];
  email: string;
  linkedin: string;
  github: string;
}

const { name, title, tagline, highlights, email, linkedin, github } = Astro.props;
const [firstName, lastName] = [name.split(" ")[0], name.split(" ").slice(1).join(" ")];
---

<section class="identity-strip relative overflow-hidden px-6 pt-28 pb-16 md:pt-36 md:pb-20">
  <!-- Grid — the defining visual element -->
  <div class="grid-layer pointer-events-none absolute inset-0"></div>
  <div class="grid-cross pointer-events-none absolute inset-0"></div>

  <!-- Glow orbs — atmospheric depth -->
  <div class="orb orb-primary pointer-events-none absolute"></div>
  <div class="orb orb-accent pointer-events-none absolute"></div>
  <div class="orb orb-center pointer-events-none absolute"></div>

  <!-- Horizon line — subtle ground plane -->
  <div class="horizon pointer-events-none absolute right-0 bottom-0 left-0"></div>

  <div class="relative z-10 mx-auto max-w-5xl text-center">
    <!-- Name -->
    <h1 class="strip-el font-heading leading-[0.85] font-bold uppercase tracking-tight">
      <span class="block text-5xl text-[var(--color-heading)] sm:text-6xl md:text-7xl lg:text-8xl">{firstName}</span>
      <span class="name-last block text-4xl sm:text-5xl md:text-6xl lg:text-7xl">{lastName}</span>
    </h1>

    <!-- Title badge -->
    <div class="strip-el mt-6">
      <span class="title-badge inline-flex items-center gap-2 rounded-full px-5 py-2 text-xs font-semibold tracking-[0.2em] uppercase">
        <span class="badge-dot"></span>
        {title}
      </span>
    </div>

    <!-- Tagline -->
    <p class="strip-el mx-auto mt-6 max-w-xl text-sm leading-relaxed text-[var(--color-text-muted)] sm:text-base">
      {tagline}
    </p>

    <!-- Highlight badges -->
    <div class="strip-el mt-7 flex flex-wrap items-center justify-center gap-2.5">
      {highlights.map((h) => (
        <span class="highlight-pill rounded-full px-3.5 py-1.5 text-xs font-medium">
          <span class="text-[var(--color-heading)]">{h.label}</span>
          <span class="mx-1.5 opacity-30">/</span>
          <span class="text-[var(--color-text-muted)]">{h.detail}</span>
        </span>
      ))}
    </div>

    <!-- Social icons -->
    <div class="strip-el mt-7 flex items-center justify-center gap-3">
      <a
        href={github}
        target="_blank"
        rel="noopener noreferrer"
        class="social-icon"
        aria-label="GitHub"
      >
        <svg class="h-4 w-4" fill="currentColor" viewBox="0 0 24 24"><path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z" /></svg>
      </a>
      <a
        href={linkedin}
        target="_blank"
        rel="noopener noreferrer"
        class="social-icon"
        aria-label="LinkedIn"
      >
        <svg class="h-4 w-4" fill="currentColor" viewBox="0 0 24 24"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z" /></svg>
      </a>
      <a
        href={`mailto:${email}`}
        class="social-icon"
        aria-label="Email"
      >
        <svg class="h-4 w-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" /></svg>
      </a>
    </div>
  </div>
</section>

<style>
  /* ── Grid ── */
  .grid-layer {
    background-image:
      linear-gradient(rgba(79, 143, 247, 0.07) 1px, transparent 1px),
      linear-gradient(90deg, rgba(79, 143, 247, 0.07) 1px, transparent 1px);
    background-size: 80px 80px;
    mask-image: radial-gradient(ellipse 80% 70% at 50% 50%, black 20%, transparent 70%);
    -webkit-mask-image: radial-gradient(ellipse 80% 70% at 50% 50%, black 20%, transparent 70%);
  }

  /* Cross-hair accent at intersections */
  .grid-cross {
    background-image:
      radial-gradient(circle 1.5px at center, rgba(79, 143, 247, 0.15) 0%, transparent 100%);
    background-size: 80px 80px;
    mask-image: radial-gradient(ellipse 60% 50% at 50% 50%, black 10%, transparent 70%);
    -webkit-mask-image: radial-gradient(ellipse 60% 50% at 50% 50%, black 10%, transparent 70%);
  }

  :global(html.light) .grid-layer {
    background-image:
      linear-gradient(rgba(37, 99, 235, 0.08) 1px, transparent 1px),
      linear-gradient(90deg, rgba(37, 99, 235, 0.08) 1px, transparent 1px);
  }

  :global(html.light) .grid-cross {
    background-image:
      radial-gradient(circle 1.5px at center, rgba(37, 99, 235, 0.12) 0%, transparent 100%);
  }

  /* ── Orbs ── */
  .orb {
    border-radius: 50%;
    filter: blur(80px);
    will-change: transform;
  }

  .orb-primary {
    width: 600px;
    height: 600px;
    top: -25%;
    right: -15%;
    background: radial-gradient(circle, rgba(79, 143, 247, 0.15) 0%, transparent 65%);
    animation: orb-drift 20s ease-in-out infinite;
  }

  .orb-accent {
    width: 450px;
    height: 450px;
    bottom: -20%;
    left: -10%;
    background: radial-gradient(circle, rgba(52, 211, 153, 0.10) 0%, transparent 65%);
    animation: orb-drift 28s ease-in-out infinite reverse;
  }

  .orb-center {
    width: 350px;
    height: 350px;
    top: 30%;
    left: 45%;
    background: radial-gradient(circle, rgba(79, 143, 247, 0.06) 0%, transparent 65%);
    animation: orb-drift 22s ease-in-out 5s infinite;
  }

  :global(html.light) .orb-primary {
    background: radial-gradient(circle, rgba(37, 99, 235, 0.08) 0%, transparent 65%);
  }
  :global(html.light) .orb-accent {
    background: radial-gradient(circle, rgba(5, 150, 105, 0.06) 0%, transparent 65%);
  }
  :global(html.light) .orb-center {
    background: radial-gradient(circle, rgba(37, 99, 235, 0.04) 0%, transparent 65%);
  }

  @keyframes orb-drift {
    0%, 100% { transform: translate(0, 0) scale(1); }
    33% { transform: translate(25px, -35px) scale(1.04); }
    66% { transform: translate(-15px, 20px) scale(0.96); }
  }

  /* ── Horizon ── */
  .horizon {
    height: 1px;
    background: linear-gradient(90deg, transparent, rgba(79, 143, 247, 0.12), transparent);
  }
  :global(html.light) .horizon {
    background: linear-gradient(90deg, transparent, rgba(37, 99, 235, 0.10), transparent);
  }

  /* ── Name ── */
  .name-last {
    color: var(--color-text-muted);
    opacity: 0.6;
  }

  /* ── Title badge ── */
  .title-badge {
    border: 1px solid rgba(79, 143, 247, 0.25);
    background: rgba(79, 143, 247, 0.06);
    color: var(--color-primary);
    backdrop-filter: blur(8px);
  }
  :global(html.light) .title-badge {
    border-color: rgba(37, 99, 235, 0.2);
    background: rgba(37, 99, 235, 0.05);
  }
  .badge-dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--color-accent);
    box-shadow: 0 0 8px rgba(52, 211, 153, 0.5);
    animation: dot-pulse 3s ease-in-out infinite;
  }
  @keyframes dot-pulse {
    0%, 100% { opacity: 1; }
    50% { opacity: 0.4; }
  }

  /* ── Highlight pills ── */
  .highlight-pill {
    border: 1px solid var(--color-border);
    background: rgba(17, 17, 17, 0.5);
    backdrop-filter: blur(4px);
  }
  :global(html.light) .highlight-pill {
    background: rgba(255, 255, 255, 0.6);
  }

  /* ── Social icons ── */
  .social-icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 10px;
    border-radius: 9999px;
    border: 1px solid var(--color-border);
    color: var(--color-text-muted);
    transition: all 0.3s ease;
    background: rgba(17, 17, 17, 0.4);
    backdrop-filter: blur(4px);
    text-decoration: none;
  }
  .social-icon:hover {
    border-color: rgba(79, 143, 247, 0.4);
    color: var(--color-heading);
    box-shadow: 0 0 16px rgba(79, 143, 247, 0.12);
    transform: translateY(-2px);
  }
  :global(html.light) .social-icon {
    background: rgba(255, 255, 255, 0.6);
  }
  :global(html.light) .social-icon:hover {
    border-color: rgba(37, 99, 235, 0.3);
    box-shadow: 0 2px 8px rgba(37, 99, 235, 0.1);
  }

  /* ── Staggered entrance ── */
  .strip-el {
    animation: strip-in 0.9s cubic-bezier(0.22, 1, 0.36, 1) both;
  }
  .strip-el:nth-child(1) { animation-delay: 0s; }
  .strip-el:nth-child(2) { animation-delay: 0.08s; }
  .strip-el:nth-child(3) { animation-delay: 0.16s; }
  .strip-el:nth-child(4) { animation-delay: 0.24s; }
  .strip-el:nth-child(5) { animation-delay: 0.32s; }
  .strip-el:nth-child(6) { animation-delay: 0.40s; }

  @keyframes strip-in {
    from {
      opacity: 0;
      transform: translateY(24px);
      filter: blur(4px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
      filter: blur(0);
    }
  }
</style>
