---
import HubCard from "./HubCard.astro";

interface Props {
  email: string;
}

const { email } = Astro.props;
---

<HubCard title="Contact" href={`mailto:${email}`} accentColor="#6ee7b7">
  <svg slot="icon" class="h-5 w-5" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M21.75 6.75v10.5a2.25 2.25 0 01-2.25 2.25h-15a2.25 2.25 0 01-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0019.5 4.5h-15a2.25 2.25 0 00-2.25 2.25m19.5 0v.243a2.25 2.25 0 01-1.07 1.916l-7.5 4.615a2.25 2.25 0 01-2.36 0L3.32 8.91a2.25 2.25 0 01-1.07-1.916V6.75" /></svg>

  <p class="text-sm leading-relaxed text-[var(--color-text-muted)]">
    Open to collaboration, interesting problems, and conversations about ML infrastructure.
  </p>
  <div class="mt-auto flex items-center gap-2 pt-3">
    <span class="inline-flex items-center gap-1.5 text-xs font-medium text-[var(--color-accent)] transition-colors">
      <svg class="h-3.5 w-3.5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M21.75 6.75v10.5a2.25 2.25 0 01-2.25 2.25h-15a2.25 2.25 0 01-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0019.5 4.5h-15a2.25 2.25 0 00-2.25 2.25m19.5 0v.243a2.25 2.25 0 01-1.07 1.916l-7.5 4.615a2.25 2.25 0 01-2.36 0L3.32 8.91a2.25 2.25 0 01-1.07-1.916V6.75" /></svg>
      {email}
    </span>
  </div>
</HubCard>
