---
interface Props {
  prevPost?: { slug: string; title: string } | null;
  nextPost?: { slug: string; title: string } | null;
}

const { prevPost, nextPost } = Astro.props;
const hasNavigation = prevPost || nextPost;
---

{
  hasNavigation && (
    <nav
      aria-label="Post navigation"
      class="mt-12 flex items-stretch justify-between gap-4 border-t border-[var(--color-border)] pt-8"
    >
      {/* Previous post */}
      {prevPost ? (
        <a
          href={`/blog/${prevPost.slug}/`}
          class="group flex max-w-[48%] flex-1 flex-col items-start gap-1 rounded-xl border border-[var(--color-border)] p-4 no-underline transition-all duration-300 hover:border-[var(--color-primary)]/30 sm:p-5"
        >
          <span class="inline-flex items-center gap-1 text-xs font-medium uppercase tracking-wider text-[var(--color-text-muted)]">
            <svg
              class="h-3.5 w-3.5 transition-transform duration-300 group-hover:-translate-x-0.5"
              fill="none"
              stroke="currentColor"
              viewBox="0 0 24 24"
              aria-hidden="true"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M15 19l-7-7 7-7"
              />
            </svg>
            Previous
          </span>
          <span class="text-sm font-medium text-[var(--color-heading)] transition-colors duration-300 group-hover:text-[var(--color-primary)]">
            {prevPost.title}
          </span>
        </a>
      ) : (
        <div class="flex-1" />
      )}

      {/* Next post */}
      {nextPost ? (
        <a
          href={`/blog/${nextPost.slug}/`}
          class="group flex max-w-[48%] flex-1 flex-col items-end gap-1 rounded-xl border border-[var(--color-border)] p-4 no-underline transition-all duration-300 hover:border-[var(--color-primary)]/30 sm:p-5"
        >
          <span class="inline-flex items-center gap-1 text-xs font-medium uppercase tracking-wider text-[var(--color-text-muted)]">
            Next
            <svg
              class="h-3.5 w-3.5 transition-transform duration-300 group-hover:translate-x-0.5"
              fill="none"
              stroke="currentColor"
              viewBox="0 0 24 24"
              aria-hidden="true"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M9 5l7 7-7 7"
              />
            </svg>
          </span>
          <span class="text-sm font-medium text-[var(--color-heading)] transition-colors duration-300 group-hover:text-[var(--color-primary)]">
            {nextPost.title}
          </span>
        </a>
      ) : (
        <div class="flex-1" />
      )}
    </nav>
  )
}
