---
interface Props {
  email: string;
  linkedin: string;
  github: string;
}

const { email, linkedin, github } = Astro.props;
---

<section id="contact" class="relative overflow-hidden px-6 py-24 md:py-32">
  <!-- Background glow -->
  <div class="pointer-events-none absolute inset-0">
    <div class="contact-glow absolute bottom-0 left-1/2 h-[400px] w-[600px] -translate-x-1/2 rounded-full blur-[120px]"></div>
  </div>

  <div class="relative z-10 mx-auto max-w-3xl text-center">
    <div class="contact-animate mb-4 flex items-center justify-center gap-3">
      <div class="h-[2px] w-8 rounded-full bg-[var(--color-primary)]"></div>
      <span class="text-xs font-semibold tracking-[0.25em] text-[var(--color-primary)] uppercase">Contact</span>
      <div class="h-[2px] w-8 rounded-full bg-[var(--color-primary)]"></div>
    </div>

    <h2 class="contact-animate font-heading text-4xl font-bold uppercase text-[var(--color-heading)] sm:text-5xl md:text-6xl">
      Let's Connect
    </h2>

    <p class="contact-animate mt-4 text-base leading-relaxed text-[var(--color-text-muted)] sm:text-lg">
      Open to collaboration, interesting problems, and conversations about ML infrastructure.
    </p>

    <div class="contact-animate mt-10">
      <a
        href={`mailto:${email}`}
        class="cta-button group relative inline-flex items-center gap-2.5 overflow-hidden rounded-full px-8 py-3.5 text-sm font-semibold tracking-wider uppercase no-underline transition-all duration-500"
      >
        <svg class="relative z-10 h-4 w-4 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"></path>
        </svg>
        <span class="relative z-10 text-white">Send an Email</span>
      </a>
    </div>

    <div class="contact-animate mt-8 flex items-center justify-center gap-6">
      <a href={linkedin} target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-2 text-sm text-[var(--color-text-muted)] no-underline transition-all duration-300 hover:text-[var(--color-heading)]">
        <svg class="h-4 w-4" fill="currentColor" viewBox="0 0 24 24"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"></path></svg>
        LinkedIn
      </a>
      <span class="text-[var(--color-border)]">/</span>
      <a href={github} target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-2 text-sm text-[var(--color-text-muted)] no-underline transition-all duration-300 hover:text-[var(--color-heading)]">
        <svg class="h-4 w-4" fill="currentColor" viewBox="0 0 24 24"><path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"></path></svg>
        GitHub
      </a>
    </div>
  </div>
</section>

<style>
  .contact-glow { background: rgba(79, 143, 247, 0.04); }
  :global(html.light) .contact-glow { background: rgba(37, 99, 235, 0.03); }

  .cta-button {
    background: linear-gradient(135deg, var(--color-primary) 0%, var(--color-primary-dark) 100%);
    box-shadow: 0 0 20px rgba(79, 143, 247, 0.2), inset 0 1px 0 rgba(255, 255, 255, 0.1);
  }
  .cta-button:hover {
    box-shadow: 0 0 40px rgba(79, 143, 247, 0.35), inset 0 1px 0 rgba(255, 255, 255, 0.15);
    transform: translateY(-1px);
  }
  :global(html.light) .cta-button {
    box-shadow: 0 2px 8px rgba(37, 99, 235, 0.3);
  }
  :global(html.light) .cta-button:hover {
    box-shadow: 0 4px 16px rgba(37, 99, 235, 0.4);
  }

  .contact-animate {
    animation: contact-fade 0.8s cubic-bezier(0.22, 1, 0.36, 1) both;
    animation-timeline: view();
    animation-range: entry 0% entry 30%;
  }
  @supports not (animation-timeline: view()) {
    .contact-animate { animation: contact-fade 0.8s cubic-bezier(0.22, 1, 0.36, 1) both; }
  }
  @keyframes contact-fade {
    from { opacity: 0; transform: translateY(24px); }
    to { opacity: 1; transform: translateY(0); }
  }
</style>
