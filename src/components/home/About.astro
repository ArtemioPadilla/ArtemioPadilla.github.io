---
interface Highlight {
  label: string;
  detail: string;
}

interface Props {
  heading: string;
  description: string;
  highlights: Highlight[];
}

const { heading, description, highlights } = Astro.props;
---

<section id="about" class="relative px-6 py-24 md:py-32">
  <div class="mx-auto max-w-6xl">
    <!-- Section label -->
    <div class="about-animate mb-4 flex items-center gap-3">
      <div class="h-[2px] w-8 rounded-full bg-[var(--color-primary)]"></div>
      <span class="text-xs font-semibold tracking-[0.25em] text-[var(--color-primary)] uppercase">About</span>
    </div>

    <!-- Content grid -->
    <div class="grid gap-12 lg:grid-cols-2 lg:gap-20">
      <!-- Text column -->
      <div class="about-animate">
        <h2 class="font-heading text-3xl font-bold uppercase leading-tight text-[var(--color-heading)] sm:text-4xl md:text-5xl">
          {heading}
        </h2>
        <p class="mt-6 text-base leading-[1.8] text-[var(--color-text-muted)] sm:text-lg">
          {description}
        </p>
      </div>

      <!-- Highlights grid -->
      <div class="grid grid-cols-2 gap-4">
        {
          highlights.map((highlight, i) => (
            <div
              class="about-animate highlight-card card-surface group relative overflow-hidden rounded-2xl border border-[var(--color-border)] bg-[var(--color-surface)] p-6 transition-all duration-500 hover:border-[var(--color-primary)]/30"
              style={`animation-delay: ${0.1 * (i + 1)}s`}
            >
              <div class="highlight-glow" />
              <div class="relative z-10">
                <div class="text-3xl font-bold tracking-tight text-[var(--color-heading)] sm:text-4xl">
                  {highlight.label}
                </div>
                <div class="mt-2 text-sm leading-relaxed text-[var(--color-text-muted)]">
                  {highlight.detail}
                </div>
              </div>
            </div>
          ))
        }
      </div>
    </div>
  </div>
</section>

<style>
  .highlight-glow {
    position: absolute;
    inset: 0;
    opacity: 0;
    transition: opacity 0.5s ease;
    background: radial-gradient(
      circle at 30% 30%,
      rgba(79, 143, 247, 0.08) 0%,
      transparent 60%
    );
  }

  .highlight-card:hover .highlight-glow {
    opacity: 1;
  }

  :global(html.light) .highlight-glow {
    background: radial-gradient(
      circle at 30% 30%,
      rgba(37, 99, 235, 0.04) 0%,
      transparent 60%
    );
  }

  .about-animate {
    animation: about-fade-in 0.8s cubic-bezier(0.22, 1, 0.36, 1) both;
    animation-timeline: view();
    animation-range: entry 0% entry 30%;
  }

  @supports not (animation-timeline: view()) {
    .about-animate {
      animation: about-fade-in 0.8s cubic-bezier(0.22, 1, 0.36, 1) both;
    }
  }

  @keyframes about-fade-in {
    from { opacity: 0; transform: translateY(24px); }
    to { opacity: 1; transform: translateY(0); }
  }
</style>
