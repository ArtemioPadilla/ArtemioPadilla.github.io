---
interface Props {
  name: string;
  title: string;
  tagline: string;
  cta: { text: string; href: string };
}

const { name, title, tagline, cta } = Astro.props;

const [firstName, lastName] = [name.split(" ")[0], name.split(" ").slice(1).join(" ")];
---

<section class="hero-section relative flex min-h-screen items-center justify-center overflow-hidden px-6">
  <!-- Glow orbs -->
  <div class="hero-orb hero-orb-1 pointer-events-none absolute"></div>
  <div class="hero-orb hero-orb-2 pointer-events-none absolute"></div>
  <div class="hero-orb hero-orb-3 pointer-events-none absolute"></div>

  <!-- Subtle grid -->
  <div class="hero-grid pointer-events-none absolute inset-0"></div>

  <div class="relative z-10 mx-auto max-w-5xl text-center">
    <!-- Name -->
    <h1 class="hero-name font-heading leading-[0.85] font-bold uppercase tracking-tight">
      <span class="block text-6xl text-[var(--color-heading)] sm:text-7xl md:text-8xl lg:text-[9rem]">{firstName}</span>
      <span class="block text-5xl text-[var(--color-text-muted)] sm:text-6xl md:text-7xl lg:text-[7rem]">{lastName}</span>
    </h1>

    <!-- Title -->
    <p class="hero-title mt-6 text-sm font-medium tracking-[0.3em] text-[var(--color-primary)] uppercase sm:text-base md:text-lg">
      {title}
    </p>

    <!-- Tagline -->
    <div class="hero-tagline mx-auto mt-10 max-w-xl">
      <p class="text-base leading-relaxed text-[var(--color-text-muted)] sm:text-lg">
        {tagline}
      </p>
    </div>

    <!-- CTA -->
    <div class="hero-cta mt-14 flex items-center justify-center gap-4">
      <a
        href={cta.href}
        class="cta-button group relative inline-flex items-center gap-2.5 overflow-hidden rounded-full px-8 py-3.5 text-sm font-semibold tracking-wider uppercase no-underline transition-all duration-500"
      >
        <span class="relative z-10 text-white">{cta.text}</span>
        <svg
          class="relative z-10 h-4 w-4 text-white transition-transform duration-500 group-hover:translate-x-1"
          fill="none"
          stroke="currentColor"
          viewBox="0 0 24 24"
        >
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"></path>
        </svg>
      </a>
      <a
        href="#about"
        class="rounded-full border border-[var(--color-border)] px-6 py-3.5 text-sm font-medium tracking-wide text-[var(--color-text-muted)] no-underline transition-all duration-300 hover:border-[var(--color-primary)] hover:text-[var(--color-heading)]"
      >
        Learn more
      </a>
    </div>
  </div>

  <!-- Scroll indicator -->
  <div class="absolute bottom-8 left-1/2 -translate-x-1/2">
    <div class="scroll-indicator flex flex-col items-center gap-2">
      <div class="scroll-line h-10 w-[1px] overflow-hidden">
        <div class="scroll-line-inner h-full w-full bg-gradient-to-b from-[var(--color-primary)] to-transparent"></div>
      </div>
    </div>
  </div>
</section>

<style>
  .hero-orb {
    border-radius: 50%;
    filter: blur(100px);
    will-change: transform;
  }

  .hero-orb-1 {
    width: 600px;
    height: 600px;
    top: -15%;
    right: -10%;
    background: radial-gradient(circle, rgba(79, 143, 247, 0.12) 0%, transparent 70%);
    animation: orb-float 20s ease-in-out infinite;
  }

  .hero-orb-2 {
    width: 500px;
    height: 500px;
    bottom: -10%;
    left: -15%;
    background: radial-gradient(circle, rgba(52, 211, 153, 0.08) 0%, transparent 70%);
    animation: orb-float 25s ease-in-out infinite reverse;
  }

  .hero-orb-3 {
    width: 300px;
    height: 300px;
    top: 40%;
    left: 50%;
    background: radial-gradient(circle, rgba(79, 143, 247, 0.06) 0%, transparent 70%);
    animation: orb-float 18s ease-in-out 3s infinite;
  }

  :global(html.light) .hero-orb-1 {
    background: radial-gradient(circle, rgba(37, 99, 235, 0.08) 0%, transparent 70%);
  }

  :global(html.light) .hero-orb-2 {
    background: radial-gradient(circle, rgba(5, 150, 105, 0.06) 0%, transparent 70%);
  }

  :global(html.light) .hero-orb-3 {
    background: radial-gradient(circle, rgba(37, 99, 235, 0.04) 0%, transparent 70%);
  }

  @keyframes orb-float {
    0%, 100% { transform: translate(0, 0) scale(1); }
    25% { transform: translate(30px, -40px) scale(1.05); }
    50% { transform: translate(-20px, 20px) scale(0.95); }
    75% { transform: translate(15px, 30px) scale(1.02); }
  }

  .hero-grid {
    background-image:
      linear-gradient(rgba(255, 255, 255, 0.08) 1px, transparent 1px),
      linear-gradient(90deg, rgba(255, 255, 255, 0.08) 1px, transparent 1px);
    background-size: 80px 80px;
    mask-image: radial-gradient(ellipse 80% 70% at 50% 50%, black, transparent);
    -webkit-mask-image: radial-gradient(ellipse 80% 70% at 50% 50%, black, transparent);
  }

  :global(html.light) .hero-grid {
    background-image:
      linear-gradient(rgba(0, 0, 0, 0.1) 1px, transparent 1px),
      linear-gradient(90deg, rgba(0, 0, 0, 0.1) 1px, transparent 1px);
  }

  .cta-button {
    background: linear-gradient(135deg, var(--color-primary) 0%, var(--color-primary-dark) 100%);
    box-shadow:
      0 0 20px rgba(79, 143, 247, 0.2),
      inset 0 1px 0 rgba(255, 255, 255, 0.1);
  }

  .cta-button:hover {
    box-shadow:
      0 0 40px rgba(79, 143, 247, 0.35),
      inset 0 1px 0 rgba(255, 255, 255, 0.15);
    transform: translateY(-1px);
  }

  :global(html.light) .cta-button {
    box-shadow: 0 2px 8px rgba(37, 99, 235, 0.3);
  }

  :global(html.light) .cta-button:hover {
    box-shadow: 0 4px 16px rgba(37, 99, 235, 0.4);
  }

  .hero-name { animation: fade-up 1s cubic-bezier(0.22, 1, 0.36, 1) both; }
  .hero-title { animation: fade-up 1s cubic-bezier(0.22, 1, 0.36, 1) 0.2s both; }
  .hero-tagline { animation: fade-up 1s cubic-bezier(0.22, 1, 0.36, 1) 0.4s both; }
  .hero-cta { animation: fade-up 1s cubic-bezier(0.22, 1, 0.36, 1) 0.6s both; }

  @keyframes fade-up {
    from { opacity: 0; transform: translateY(30px); }
    to { opacity: 1; transform: translateY(0); }
  }

  .scroll-indicator { animation: fade-up 1s cubic-bezier(0.22, 1, 0.36, 1) 1s both; }

  .scroll-line-inner {
    animation: scroll-down 2s ease-in-out infinite;
  }

  @keyframes scroll-down {
    0% { transform: translateY(-100%); }
    50% { transform: translateY(0); }
    100% { transform: translateY(100%); }
  }
</style>
