---
interface CollectionStat {
  value: number;
  label: string;
  color: string;
}

interface Collection {
  id: string;
  name: string;
  tagline: string;
  description: string;
  coverImage: string;
  stats: CollectionStat[];
  tags: string[];
  date: string;
  path: string;
}

const AI_ART_BASE = "https://ai-art.artemiop.com";

let collections: Collection[] = [];
try {
  const res = await fetch(`${AI_ART_BASE}/collections/manifest.json`);
  if (res.ok) {
    const data = await res.json();
    collections = data.collections ?? [];
  }
} catch {
  // Build-time fetch failed — render empty
}

// Aggregate stats across all collections
const totalStats = new Map<string, { value: number; color: string }>();
for (const col of collections) {
  for (const stat of col.stats) {
    const existing = totalStats.get(stat.label);
    if (existing) {
      existing.value += stat.value;
    } else {
      totalStats.set(stat.label, { value: stat.value, color: stat.color });
    }
  }
}

const colorMap: Record<string, string> = {
  purple: "var(--color-art-purple, #a78bfa)",
  cyan: "var(--color-art-cyan, #22d3ee)",
  rose: "var(--color-art-rose, #fb7185)",
  gold: "var(--color-art-gold, #f59e0b)",
  emerald: "var(--color-art-emerald, #34d399)",
};
---

{collections.length > 0 && (
  <section id="ai-art" class="px-6 py-24 md:py-32">
    <div class="mx-auto max-w-6xl">
      <!-- Section label -->
      <div class="mb-4 flex items-center gap-3">
        <div class="h-[2px] w-8 rounded-full bg-[var(--color-accent)]"></div>
        <span class="text-xs font-semibold tracking-[0.25em] text-[var(--color-accent)] uppercase">
          Creative Code
        </span>
      </div>

      <div class="flex flex-col gap-2 sm:flex-row sm:items-end sm:justify-between">
        <h2 class="font-heading text-3xl font-bold uppercase text-[var(--color-heading)] sm:text-4xl md:text-5xl">
          AI Art
        </h2>
        <a
          href={AI_ART_BASE}
          target="_blank"
          rel="noopener noreferrer"
          class="group inline-flex items-center gap-1.5 text-sm text-[var(--color-text-muted)] no-underline transition-colors hover:text-[var(--color-heading)]"
        >
          Browse full gallery
          <svg class="h-4 w-4 transition-transform duration-300 group-hover:translate-x-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
          </svg>
        </a>
      </div>

      <!-- Aggregate stats -->
      <div class="mt-8 flex flex-wrap gap-6">
        {[...totalStats.entries()].map(([label, { value, color }]) => (
          <div class="flex items-baseline gap-2">
            <span
              class="font-mono text-2xl font-bold"
              style={`color: ${colorMap[color] || colorMap.purple}`}
            >
              {value}
            </span>
            <span class="text-xs font-medium tracking-wider text-[var(--color-text-muted)] uppercase">
              {label}
            </span>
          </div>
        ))}
        <div class="flex items-baseline gap-2">
          <span class="font-mono text-2xl font-bold text-[var(--color-accent)]">
            {collections.length}
          </span>
          <span class="text-xs font-medium tracking-wider text-[var(--color-text-muted)] uppercase">
            {collections.length === 1 ? "Collection" : "Collections"}
          </span>
        </div>
      </div>

      <!-- Collection cards -->
      <div class="mt-10 grid gap-4 sm:grid-cols-2">
        {collections.map((col) => (
          <a
            href={`${AI_ART_BASE}/${col.path}`}
            target="_blank"
            rel="noopener noreferrer"
            class="art-card card-surface group relative flex flex-col overflow-hidden rounded-2xl border border-[var(--color-border)] bg-[var(--color-surface)] no-underline transition-all duration-500 hover:border-[var(--color-accent)]/30"
          >
            <!-- Cover image -->
            <div class="relative aspect-[16/9] overflow-hidden bg-[var(--color-surface-light)]">
              <img
                src={`${AI_ART_BASE}/${col.coverImage}`}
                alt={col.name}
                loading="lazy"
                class="h-full w-full object-cover transition-transform duration-700 group-hover:scale-105"
              />
              <div class="absolute inset-0 bg-gradient-to-t from-[var(--color-surface)] via-transparent to-transparent opacity-60"></div>

              <!-- Stats overlay -->
              <div class="absolute bottom-3 left-3 flex flex-wrap gap-2">
                {col.stats.map((s) => (
                  <span
                    class="inline-flex items-center gap-1.5 rounded-full border border-white/10 bg-black/50 px-2.5 py-1 text-xs font-medium backdrop-blur-sm"
                    style={`color: ${colorMap[s.color] || colorMap.purple}`}
                  >
                    <span class="font-mono font-bold">{s.value}</span>
                    {s.label}
                  </span>
                ))}
              </div>
            </div>

            <!-- Content -->
            <div class="flex flex-1 flex-col p-6">
              <div class="flex items-start justify-between gap-3">
                <h3 class="text-lg font-semibold text-[var(--color-heading)] transition-colors duration-300 group-hover:text-[var(--color-accent)] sm:text-xl">
                  {col.name}
                </h3>
                <svg
                  class="mt-1 h-4 w-4 shrink-0 text-[var(--color-text-muted)] transition-all duration-500 group-hover:translate-x-0.5 group-hover:-translate-y-0.5 group-hover:text-[var(--color-accent)]"
                  fill="none"
                  stroke="currentColor"
                  viewBox="0 0 24 24"
                >
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 17L17 7M17 7H7M17 7v10" />
                </svg>
              </div>

              <p class="mt-2 text-sm leading-relaxed text-[var(--color-text-muted)]">
                {col.tagline}
              </p>

              <!-- Tags -->
              {col.tags.length > 0 && (
                <div class="mt-4 flex flex-wrap gap-2">
                  {col.tags.slice(0, 5).map((tag) => (
                    <span class="rounded-full border border-[var(--color-border)] px-3 py-1 text-xs font-medium text-[var(--color-text-muted)] transition-all duration-300 group-hover:border-[var(--color-accent)]/20 group-hover:text-[var(--color-accent)]">
                      {tag}
                    </span>
                  ))}
                </div>
              )}
            </div>
          </a>
        ))}
      </div>

      <!-- CTA -->
      <div class="mt-8 text-center">
        <a
          href={AI_ART_BASE}
          target="_blank"
          rel="noopener noreferrer"
          class="group inline-flex items-center gap-2.5 rounded-full border border-[var(--color-border)] px-6 py-3 text-sm font-medium text-[var(--color-text-muted)] no-underline transition-all duration-300 hover:border-[var(--color-accent)] hover:text-[var(--color-heading)]"
        >
          <svg class="h-4 w-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z" />
          </svg>
          Explore the full gallery
          <svg class="h-4 w-4 transition-transform duration-300 group-hover:translate-x-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
          </svg>
        </a>
      </div>
    </div>
  </section>
)}

<style>
  .art-card {
    animation: card-enter 0.7s cubic-bezier(0.22, 1, 0.36, 1) both;
    animation-timeline: view();
    animation-range: entry 0% entry 25%;
  }

  @supports not (animation-timeline: view()) {
    .art-card {
      animation: card-enter 0.7s cubic-bezier(0.22, 1, 0.36, 1) both;
    }
  }

  @keyframes card-enter {
    from { opacity: 0; transform: translateY(20px); }
    to { opacity: 1; transform: translateY(0); }
  }
</style>
