---
interface Props {
  currentPath?: string;
}

const { currentPath = "/" } = Astro.props;

const links = [
  { href: "/", label: "Home" },
  { href: "/blog", label: "Blog" },
  { href: "/cv", label: "CV" },
  { href: "/lab", label: "Lab" },
  { href: "/projects", label: "Projects" },
  { href: "/brain", label: "Brain" },
  { href: "https://ai-art.artemiop.com", label: "Art", external: true },
  { href: "https://artemiop.com/watchboard/", label: "World Watchboard", external: true },
];
---

<nav id="main-nav" class="nav-bar fixed top-0 left-0 right-0 z-50">
  <div class="mx-auto flex max-w-6xl items-center justify-between px-6 py-4">
    <!-- Logo -->
    <a href="/" class="group flex items-center gap-1 text-xl font-bold tracking-tight text-[var(--color-heading)] no-underline">
      Artemio<span class="text-[var(--color-primary)] transition-colors group-hover:text-[var(--color-accent)]">.</span>
    </a>

    <!-- Desktop nav -->
    <div class="hidden items-center gap-1 md:flex">
      {
        links.map((link) => (
          <a
            href={link.href}
            {...(link.external ? { target: "_blank", rel: "noopener noreferrer" } : {})}
            class:list={[
              "nav-link relative px-4 py-2 text-sm font-medium tracking-wide no-underline transition-all duration-300",
              currentPath === link.href
                ? "text-[var(--color-heading)]"
                : "text-[var(--color-text-muted)] hover:text-[var(--color-heading)]",
            ]}
          >
            {link.label}
            {link.external && (
              <svg class="ml-0.5 -mt-0.5 inline-block h-3 w-3 opacity-40" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
              </svg>
            )}
            {currentPath === link.href && (
              <span class="absolute bottom-0 left-1/2 h-[2px] w-4 -translate-x-1/2 rounded-full bg-[var(--color-primary)]" />
            )}
          </a>
        ))
      }

      <div class="ml-4 h-4 w-[1px] bg-[var(--color-border)]"></div>

      <!-- Install app button (hidden until installable) -->
      <button
        id="install-btn"
        class="ml-3 hidden items-center gap-1.5 rounded-full border border-[var(--color-primary)]/30 px-3 py-1.5 text-xs font-medium text-[var(--color-primary)] transition-all duration-300 hover:bg-[var(--color-primary)]/10 hover:text-[var(--color-primary)]"
        aria-label="Install app"
      >
        <svg class="h-3.5 w-3.5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" d="M4 16v2a2 2 0 002 2h12a2 2 0 002-2v-2M12 4v12m0 0l-4-4m4 4l4-4" />
        </svg>
        Install
      </button>

      <button
        id="theme-toggle"
        class="ml-3 rounded-full p-2.5 text-[var(--color-text-muted)] transition-all duration-300 hover:text-[var(--color-heading)]"
        aria-label="Toggle theme"
      >
        <svg
          class="dark-icon h-4 w-4"
          fill="none"
          stroke="currentColor"
          viewBox="0 0 24 24"
        >
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            stroke-width="2"
            d="M20.354 15.354A9 9 0 018.646 3.646 9.003 9.003 0 0012 21a9.003 9.003 0 008.354-5.646z"
          ></path>
        </svg>
        <svg
          class="light-icon hidden h-4 w-4"
          fill="none"
          stroke="currentColor"
          viewBox="0 0 24 24"
        >
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            stroke-width="2"
            d="M12 3v1m0 16v1m9-9h-1M4 12H3m15.364 6.364l-.707-.707M6.343 6.343l-.707-.707m12.728 0l-.707.707M6.343 17.657l-.707.707M16 12a4 4 0 11-8 0 4 4 0 018 0z"
          ></path>
        </svg>
      </button>
    </div>

    <!-- Mobile menu button -->
    <button
      id="mobile-menu-btn"
      class="rounded-full p-2 text-[var(--color-text-muted)] transition-colors hover:text-[var(--color-heading)] md:hidden"
      aria-label="Toggle menu"
    >
      <svg class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path
          stroke-linecap="round"
          stroke-linejoin="round"
          stroke-width="1.5"
          d="M4 6h16M4 12h16M4 18h16"></path>
      </svg>
    </button>
  </div>

  <!-- Mobile menu -->
  <div
    id="mobile-menu"
    class="hidden border-t border-[var(--color-border)] bg-[var(--color-bg)] px-6 pb-6 pt-2 md:hidden"
  >
    {
      links.map((link) => (
        <a
          href={link.href}
          {...(link.external ? { target: "_blank", rel: "noopener noreferrer" } : {})}
          class:list={[
            "block py-3 text-sm font-medium no-underline transition-colors",
            currentPath === link.href
              ? "text-[var(--color-primary)]"
              : "text-[var(--color-text-muted)] hover:text-[var(--color-heading)]",
          ]}
        >
          {link.label}
          {link.external && (
            <svg class="ml-1 -mt-0.5 inline-block h-3 w-3 opacity-40" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
            </svg>
          )}
        </a>
      ))
    }
    <!-- Mobile install button -->
    <button
      id="mobile-install-btn"
      class="mt-2 hidden w-full items-center justify-center gap-2 rounded-xl border border-[var(--color-primary)]/30 py-2.5 text-sm font-medium text-[var(--color-primary)] transition-all hover:bg-[var(--color-primary)]/10"
      aria-label="Install app"
    >
      <svg class="h-4 w-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" d="M4 16v2a2 2 0 002 2h12a2 2 0 002-2v-2M12 4v12m0 0l-4-4m4 4l4-4" />
      </svg>
      Install App
    </button>
    <!-- Mobile theme toggle -->
    <div class="mt-2 border-t border-[var(--color-border)] pt-3">
      <button
        id="mobile-theme-toggle"
        class="flex items-center gap-2 py-2 text-sm font-medium text-[var(--color-text-muted)] transition-colors hover:text-[var(--color-heading)]"
        aria-label="Toggle theme"
      >
        <svg class="mobile-dark-icon h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20.354 15.354A9 9 0 018.646 3.646 9.003 9.003 0 0012 21a9.003 9.003 0 008.354-5.646z" />
        </svg>
        <svg class="mobile-light-icon hidden h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 3v1m0 16v1m9-9h-1M4 12H3m15.364 6.364l-.707-.707M6.343 6.343l-.707-.707m12.728 0l-.707.707M6.343 17.657l-.707.707M16 12a4 4 0 11-8 0 4 4 0 018 0z" />
        </svg>
        <span class="mobile-theme-label">Switch theme</span>
      </button>
    </div>
  </div>
</nav>

<style>
  .nav-bar {
    background: var(--color-bg);
    border-bottom: 1px solid var(--color-border);
    backdrop-filter: blur(20px) saturate(1.4);
    -webkit-backdrop-filter: blur(20px) saturate(1.4);
    transition: all 0.3s ease;
  }

  :global(html:not(.light)) .nav-bar {
    background: rgba(9, 9, 11, 0.6);
    border-bottom-color: rgba(255, 255, 255, 0.04);
  }

  :global(html:not(.light)) .nav-bar.scrolled {
    background: rgba(9, 9, 11, 0.85);
    border-bottom-color: rgba(255, 255, 255, 0.06);
  }

  :global(html.light) .nav-bar {
    background: rgba(250, 250, 250, 0.8);
    border-bottom-color: var(--color-border);
  }
</style>

<script>
  const btn = document.getElementById("mobile-menu-btn");
  const menu = document.getElementById("mobile-menu");
  btn?.addEventListener("click", () => menu?.classList.toggle("hidden"));

  const themeBtn = document.getElementById("theme-toggle");
  const mobileThemeBtn = document.getElementById("mobile-theme-toggle");
  const darkIcon = themeBtn?.querySelector(".dark-icon");
  const lightIcon = themeBtn?.querySelector(".light-icon");
  const mobileDarkIcon = mobileThemeBtn?.querySelector(".mobile-dark-icon");
  const mobileLightIcon = mobileThemeBtn?.querySelector(".mobile-light-icon");

  function updateIcons() {
    const isLight = document.documentElement.classList.contains("light");
    darkIcon?.classList.toggle("hidden", isLight);
    lightIcon?.classList.toggle("hidden", !isLight);
    mobileDarkIcon?.classList.toggle("hidden", isLight);
    mobileLightIcon?.classList.toggle("hidden", !isLight);
  }

  updateIcons();

  function toggleTheme() {
    const isLight = document.documentElement.classList.contains("light");
    document.documentElement.classList.toggle("light", !isLight);
    document.documentElement.classList.toggle("dark", isLight);
    localStorage.setItem("theme", isLight ? "dark" : "light");
    updateIcons();
  }

  themeBtn?.addEventListener("click", toggleTheme);
  mobileThemeBtn?.addEventListener("click", toggleTheme);

  const nav = document.getElementById("main-nav");
  window.addEventListener("scroll", () => {
    nav?.classList.toggle("scrolled", window.scrollY > 20);
  }, { passive: true });

  // PWA install prompt
  let deferredPrompt: any = null;
  const installBtn = document.getElementById("install-btn");
  const mobileInstallBtn = document.getElementById("mobile-install-btn");

  function showInstallButtons() {
    installBtn?.classList.remove("hidden");
    installBtn?.classList.add("flex");
    mobileInstallBtn?.classList.remove("hidden");
    mobileInstallBtn?.classList.add("flex");
  }

  function hideInstallButtons() {
    installBtn?.classList.add("hidden");
    installBtn?.classList.remove("flex");
    mobileInstallBtn?.classList.add("hidden");
    mobileInstallBtn?.classList.remove("flex");
  }

  window.addEventListener("beforeinstallprompt", (e) => {
    e.preventDefault();
    deferredPrompt = e;
    showInstallButtons();
  });

  async function handleInstall() {
    if (!deferredPrompt) return;
    deferredPrompt.prompt();
    const { outcome } = await deferredPrompt.userChoice;
    if (outcome === "accepted") hideInstallButtons();
    deferredPrompt = null;
  }

  installBtn?.addEventListener("click", handleInstall);
  mobileInstallBtn?.addEventListener("click", handleInstall);

  window.addEventListener("appinstalled", () => hideInstallButtons());

  // iOS: detect standalone and show hint if not installed
  const isIOS = /iP(hone|ad|od)/.test(navigator.userAgent);
  const isStandalone = window.matchMedia("(display-mode: standalone)").matches
    || (navigator as any).standalone;
  if (isIOS && !isStandalone) {
    installBtn?.setAttribute("data-ios", "true");
    mobileInstallBtn?.setAttribute("data-ios", "true");
    showInstallButtons();
  }

  // iOS tap shows a tooltip instead of native prompt
  function handleIOSInstall(btn: HTMLElement) {
    if (btn.getAttribute("data-ios") !== "true") return;
    let tip = document.getElementById("ios-install-tip");
    if (tip) { tip.remove(); return; }
    tip = document.createElement("div");
    tip.id = "ios-install-tip";
    tip.innerHTML = `
      <div style="position:fixed;bottom:80px;left:50%;transform:translateX(-50%);z-index:999;
        background:var(--color-surface);border:1px solid var(--color-border);border-radius:12px;
        padding:12px 16px;font-size:13px;color:var(--color-text);max-width:280px;text-align:center;
        box-shadow:0 8px 32px rgba(0,0,0,0.3);">
        Tap <strong>Share</strong>
        <svg style="display:inline;vertical-align:-3px;width:16px;height:16px;" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" d="M4 16v2a2 2 0 002 2h12a2 2 0 002-2v-2m-4-8l-4-4m0 0L8 8m4-4v12"/>
        </svg>
        then <strong>"Add to Home Screen"</strong>
        <button onclick="this.parentElement.parentElement.remove()"
          style="display:block;margin:8px auto 0;font-size:11px;color:var(--color-text-muted);cursor:pointer;background:none;border:none;">
          Dismiss
        </button>
      </div>`;
    document.body.appendChild(tip);
    setTimeout(() => tip?.remove(), 8000);
  }

  installBtn?.addEventListener("click", (e) => {
    if (installBtn.getAttribute("data-ios") === "true") {
      e.stopPropagation();
      handleIOSInstall(installBtn);
    }
  });
  mobileInstallBtn?.addEventListener("click", (e) => {
    if (mobileInstallBtn.getAttribute("data-ios") === "true") {
      e.stopPropagation();
      handleIOSInstall(mobileInstallBtn);
    }
  });
</script>
