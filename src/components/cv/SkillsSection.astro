---
import type { Skills } from "@/types/cv";

interface Props {
  skills: Skills;
}

const { skills } = Astro.props;

interface SkillCategory {
  label: string;
  items: string[];
}

const categories: SkillCategory[] = [
  { label: "Languages", items: skills.languages },
  ...(skills.cloudAndMLOps ? [{ label: "Cloud & MLOps", items: skills.cloudAndMLOps }] : []),
  ...(skills.databases?.relational ? [{ label: "Relational Databases", items: skills.databases.relational }] : []),
  ...(skills.databases?.nosql ? [{ label: "NoSQL Databases", items: skills.databases.nosql }] : []),
  ...(skills.bigData ? [{ label: "Big Data", items: skills.bigData }] : []),
  ...(skills.machineLearning ? [{ label: "Machine Learning", items: skills.machineLearning }] : []),
  ...(skills.visualization ? [{ label: "Visualization", items: skills.visualization }] : []),
  ...(skills.tools ? [{ label: "Tools", items: skills.tools }] : []),
  ...(skills.design ? [{ label: "Design", items: skills.design }] : []),
];
---

<section id="skills" class="scroll-mt-8">
  <h2 class="font-heading text-3xl font-bold text-text uppercase tracking-wide mb-8">
    Technical Skills
  </h2>

  <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
    {categories.map((category) => (
      <div class="skill-category">
        <h3 class="text-xs font-semibold text-primary uppercase tracking-wider mb-3">
          {category.label}
        </h3>
        <div class="flex flex-wrap gap-1.5">
          {category.items.map((skill) => (
            <span class="skill-pill">{skill}</span>
          ))}
        </div>
      </div>
    ))}
  </div>
</section>

<style>
  .skill-category {
    background-color: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: 0.75rem;
    padding: 1.25rem;
  }

  .skill-pill {
    display: inline-block;
    padding: 0.25rem 0.625rem;
    border-radius: 0.375rem;
    font-size: 0.8125rem;
    color: var(--color-text);
    background-color: var(--color-surface-light);
    border: 1px solid var(--color-border);
    transition: border-color 0.15s ease, color 0.15s ease;
  }

  .skill-pill:hover {
    border-color: var(--color-primary);
    color: var(--color-primary);
  }
</style>
