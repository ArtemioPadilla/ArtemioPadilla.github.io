---
import type { Education } from "@/types/cv";
import { formatDate } from "@/utils/date-formatter";

interface Props {
  education: Education[];
}

const { education } = Astro.props;
---

<section id="education" class="scroll-mt-8">
  <h2 class="font-heading text-3xl font-bold text-text uppercase tracking-wide mb-6">
    Education
  </h2>

  <div class="space-y-0">
    {education.map((edu) => (
      <div class="education-entry">
        <div class="flex flex-col sm:flex-row sm:items-start sm:justify-between gap-1 mb-2">
          <div>
            <h3 class="text-lg font-semibold text-text">{edu.degree}</h3>
            <p class="text-primary font-medium">{edu.institution}</p>
          </div>

          <div class="flex items-center gap-2 flex-shrink-0">
            <span class="text-sm text-text-muted whitespace-nowrap">
              {formatDate(edu.startDate)} &ndash; {formatDate(edu.endDate)}
            </span>
            {edu.expectedEndDate && !edu.endDate && (
              <span class="text-xs text-text-muted">(Expected {formatDate(edu.expectedEndDate)})</span>
            )}
          </div>
        </div>

        <div class="space-y-2 mt-2">
          {edu.gpa && (
            <p class="text-sm text-text-muted">
              <span class="font-medium text-text">GPA:</span> {edu.gpa}
            </p>
          )}

          {edu.achievement && (
            <p class="text-sm text-text-muted">
              <span class="font-medium text-accent">Achievement:</span> {edu.achievement}
            </p>
          )}

          {edu.coursework && (
            <div class="mt-2">
              <p class="text-xs font-semibold text-text uppercase tracking-wider mb-1.5">
                Relevant Coursework
              </p>
              <p class="text-sm text-text-muted leading-relaxed">{edu.coursework}</p>
            </div>
          )}
        </div>
      </div>
    ))}
  </div>
</section>

<style>
  .education-entry {
    padding: 1.25rem 0;
    border-bottom: 1px solid var(--color-border);
  }

  .education-entry:last-child {
    border-bottom: none;
  }
</style>
