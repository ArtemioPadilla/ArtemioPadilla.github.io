---
import type { Certification } from "@/types/cv";
import { formatDate } from "@/utils/date-formatter";

interface Props {
  certifications: Certification[];
}

const { certifications } = Astro.props;

// Group certifications by type
const grouped = certifications.reduce<Record<string, Certification[]>>((acc, cert) => {
  const type = cert.type || "Other";
  if (!acc[type]) acc[type] = [];
  acc[type].push(cert);
  return acc;
}, {});

const typeOrder = [
  "High Specialty Certificate",
  "Language Certificate",
  "Online Course",
  "Course/Workshop",
  "Workshop",
];

const sortedTypes = Object.keys(grouped).sort((a, b) => {
  const idxA = typeOrder.indexOf(a);
  const idxB = typeOrder.indexOf(b);
  if (idxA === -1 && idxB === -1) return a.localeCompare(b);
  if (idxA === -1) return 1;
  if (idxB === -1) return -1;
  return idxA - idxB;
});

const typeBadgeColors: Record<string, string> = {
  "High Specialty Certificate": "bg-accent/15 text-accent border-accent/25",
  "Language Certificate": "bg-purple-500/15 text-purple-400 border-purple-500/25",
  "Online Course": "bg-primary/15 text-primary border-primary/25",
  "Course/Workshop": "bg-yellow-500/15 text-yellow-400 border-yellow-500/25",
  Workshop: "bg-orange-500/15 text-orange-400 border-orange-500/25",
};
---

<section id="certifications" class="scroll-mt-8">
  <h2 class="font-heading text-3xl font-bold text-text uppercase tracking-wide mb-6">
    Certifications & Courses
  </h2>

  <div class="space-y-8">
    {sortedTypes.map((type) => (
      <div>
        <h3 class="text-sm font-semibold text-text uppercase tracking-wider mb-4 flex items-center gap-2">
          <span class={`inline-flex items-center px-2.5 py-0.5 rounded text-xs font-medium border ${typeBadgeColors[type] || "bg-surface-light text-text-muted border-border"}`}>
            {type}
          </span>
        </h3>

        <div class="space-y-0">
          {grouped[type].map((cert) => (
            <div class="cert-entry">
              <div class="flex flex-col sm:flex-row sm:items-start sm:justify-between gap-1">
                <div class="flex-1">
                  <h4 class="text-sm font-medium text-text">
                    {cert.url ? (
                      <a
                        href={cert.url}
                        target="_blank"
                        rel="noopener noreferrer"
                        class="hover:text-primary transition-colors"
                      >
                        {cert.name}
                        <svg class="inline-block w-3 h-3 ml-1 opacity-50" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                          <path stroke-linecap="round" stroke-linejoin="round" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
                        </svg>
                      </a>
                    ) : (
                      cert.name
                    )}
                  </h4>
                  {cert.issuer && (
                    <p class="text-xs text-text-muted mt-0.5">{cert.issuer}</p>
                  )}
                </div>

                <span class="text-xs text-text-muted flex-shrink-0">
                  {formatDate(cert.date)}
                </span>
              </div>
            </div>
          ))}
        </div>
      </div>
    ))}
  </div>
</section>

<style>
  .cert-entry {
    padding: 0.75rem 0;
    border-bottom: 1px solid var(--color-border);
  }

  .cert-entry:last-child {
    border-bottom: none;
  }
</style>
