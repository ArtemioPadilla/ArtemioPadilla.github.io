---
import type { Experience } from "@/types/cv";
import { formatDate, formatHighlight } from "@/utils/date-formatter";

interface Props {
  experience: Experience;
}

const { experience } = Astro.props;
const { title, company, location, startDate, endDate, current, highlights } = experience;
---

<div class="experience-item">
  <div class="flex flex-col sm:flex-row sm:items-start sm:justify-between gap-1 mb-3">
    <div>
      <h3 class="text-lg font-semibold text-text">{title}</h3>
      <p class="text-primary font-medium">
        {company}
        {location && <span class="text-text-muted font-normal"> &middot; {location}</span>}
      </p>
    </div>

    <div class="flex items-center gap-2 flex-shrink-0">
      <span class="text-sm text-text-muted whitespace-nowrap">
        {formatDate(startDate)} &ndash; {formatDate(endDate)}
      </span>
      {current && (
        <span class="inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium bg-accent/20 text-accent border border-accent/30">
          Current
        </span>
      )}
    </div>
  </div>

  {highlights && highlights.length > 0 && (
    <ul class="space-y-2 mt-3">
      {highlights.map((highlight) => (
        <li class="flex items-start gap-3 text-sm text-text-muted leading-relaxed">
          <span class="mt-1.5 w-1 h-1 rounded-full bg-border flex-shrink-0"></span>
          <span set:html={formatHighlight(highlight)} />
        </li>
      ))}
    </ul>
  )}
</div>

<style>
  .experience-item {
    padding: 1.25rem 0;
    border-bottom: 1px solid var(--color-border);
  }

  .experience-item:last-child {
    border-bottom: none;
  }
</style>
