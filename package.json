{
  "name": "artemiopadilla-portfolio",
  "version": "2.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "astro dev",
    "build": "npm run validate:cv && astro build",
    "preview": "astro preview",
    "validate:cv": "npx tsx scripts/validate-cv.ts --check",
