    "astro": "astro"
  },
  "dependencies": {
    "@astrojs/preact": "^4.0.0",
    "@astrojs/sitemap": "^3.3.0",
    "astro": "^5.5.0",
    "jspdf": "^2.5.2",
    "preact": "^10.25.0",
    "tsparticles-engine": "^2.12.0",
    "tsparticles-slim": "^2.12.0",
    "typed.js": "^3.0.0"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.0.0",
    "ajv": "^8.12.0",
    "ajv-formats": "^2.1.1",
    "tailwindcss": "^4.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0"
  }
}
